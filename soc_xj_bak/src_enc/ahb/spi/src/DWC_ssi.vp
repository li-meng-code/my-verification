//Top Level Module for Synchronous Serial interface
    
`include "DWC_ssi_all_includes.vh"

module DWC_ssi
  (
                 // --------------------------------------
                 // -- Input and Output Port Declaration
                 // --------------------------------------
                 input    wire                   ssi_clk        // DWC_ssi core clock signal
                 ,input    wire                   ssi_rst_n      // Core async Reset Signal
                 ,//--------------------------------------------------
                 // AHB Interface Signals
                 //--------------------------------------------------
                 input   wire                                   hclk
                 ,input   wire                                   hresetn
                 ,input   wire                                   hsel
                 ,input   wire  [31:0]                           haddr
                 ,input   wire  [2:0]                            hsize
                 ,input   wire  [1:0]                            htrans
                 ,input   wire  [2:0]                            hburst
                 ,input   wire                                   hready
                 ,input   wire                                   hwrite
                 ,input   wire  [31:0]                           hwdata
                 ,output  wire [31:0]                            hrdata
                 ,output  wire [1:0]                             hresp
                 ,output  wire                                   hready_resp
                 ,input    wire                   dma_tx_ack     // DMA Tx burst end
                 ,input    wire                   dma_rx_ack     // DMA Rx burst end
                 ,input    wire   [`SERIOW-1:0]   rxd            // Receive Data Signal
                 ,input    wire                   ss_in_n        // Slave Select Input
                 ,output    wire                  dma_tx_req     // Transmit FIFO DMA Request
                 ,output    wire                  dma_rx_req     // Receive FIFO DMA request
                 ,output    wire                  dma_tx_single  // DMA TRansmit FIFO Single Signal
                 ,output    wire                  dma_rx_single  // DMA Receive FIFO Single Signal
                 ,output    wire                  ssi_sleep
                 ,output    wire [`SERIOW-1:0]  txd            // Transmit Data Signal
                 ,output    wire [`SERIOW-1:0]   ssi_oe_n       // Output enable Signal
                 ,output    wire                  ss_0_n         // Slave Select Output
                 ,output   wire [1:0]             spi_mode        // SPI Frame format signal
                 ,output    wire                  ss_1_n         // Slave Select Output
                 ,output  wire                    sclk_out       // Serial bit-rate clock
                 ,output    wire                  ssi_intr       // combined interrupt output
                 );


  // --------------------------------------
  // -- Wire Declaration
  // --------------------------------------

  
