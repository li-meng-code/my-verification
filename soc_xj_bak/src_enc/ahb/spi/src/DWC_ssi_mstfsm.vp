// File    : DWC_ssi_mstfsm.v
//
//
// Abstract: FSM controller for DWC_ssi serial master macrocell
//
// -------------------------------------------------------------------
// -------------------------------------------------------------------

`include "DWC_ssi_all_includes.vh"

module DWC_ssi_mstfsm
  (
  // ------------------------------------------------------
  // -- Port Declaration
  // ------------------------------------------------------
  input                     ssi_clk,      // SSI peripheral clock
  input                     ssi_clk_en,   // ssi_clk enable
  input                     ssi_rst_n,    // SSI async reset
  input                     ssi_en_int,   // internal SSI enable signal
  input                     start_xfer,   // start transfer signal
  input                     tx_empty,

  input                     sclk_re,      // sclk_out rising edge
  input                     sclk_fe,      // sclk_out falling edge
  input [2:0]               mwcr,         // Microwire control register
  input [1:0]               frf,          // data frame format (spi, ssp, microwire)
  input                     scph,         // spi clock phase
  input                     ss_tgl_en,    // Slave Select toggle enable signal
  input [1:0]               tmod,         // transfer mode
  input [`DFS_W-1:0]        dfs,          // data frame size
  input [3:0]               cfs,          // Microwire control frame size
  input                     spi_dyn_ws_en,  // SPI Dynamic Wait State enable 
  input [3:0]               spi_max_ws,     // SPI Maximum wait state register
  input [2:0]               spi_dyn_ws,     // SPI Dynamic state register
  input                     slv_status,     // Slave ready status
  output reg                spite_tgl,      // SPI transmit error toggle
  input [16:0]              ndf,          // number of data frames
  input                     srl_test,     // loop back mode
  input                     baud2,        // when clk divider is set to 2
  input                     ss_in_n,      // slave select input
  input                     rx_sr_busy,   // indicates that the rx sample delay buffer is still processing a data frame
  input                     rxd,
  input [1:0]               spi_frf,
  input                     spi_clk_stretch_en,
  input [`RX_ABW:0]         rxflr,
  input [`RX_ABW-1:0]       rxftlr,
  input [7:0]               rx_sr_busy_cnt,
  input [1:0]               spi_trans,
  input [1:0]               spi_inst,
  input [3:0]               spi_addr,
  input [4:0]               spi_wait,
  input [`TX_ABW:0]         tx_fifo_level,
  input [`TXFTHR_W-1:0]     txfthr,

  output reg                fsm_busy,     // busy status of the fsm
  output                    fsm_slv_sel,  // slave select for fsm
  output                    sclk_mask,    // serial data clock
  output reg
         [`SERIOW-1:0]
                   ssi_oe_n,     // SSI output enable
  output reg               fsm_sleep,    // SSI sleep signal
  output                   load_tx_shift,// load enable for tx shift reg
  output                    ssp_load_tx_shift,// load enable for tx shift reg when ssp mode and baud2
  output                    load_tx_buffer,// load enable for tx buffer//
  output                    load_rx_buf,  // load enable for rx buffer
  output                    tx_shift_en,  // shift enable for tx shifter
  output [`DFS_W-1:0]       tx_dfs,       // frame size for tx shifter
  output                    rx_shift_en,  // shiift enable for rx shifter
  output reg                fsm_multi_mst,// master collision detection
  output                    spi_dual_mode,
  output                    spi_quad_mode,
  output                    load_start_bit
  );

  // ----------------------------------------------------------
  // -- local registers and wires
  // ----------------------------------------------------------
  
`protected128
