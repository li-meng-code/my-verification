//
// Release version :  1.03a
// File Version     :        $Revision: #17 $
// Revision: $Id: //dwh/DW_ocb/DWC_ssi/ssic_ga_dev_br/src/DWC_ssi_regfile.v#17 $
//
// File    : DWC_ssi_regfile.v
//
//
// Abstract: Register Block module for the DWC_ssi macrocell
//           This module contains all of the software accessable
//           registers (except for DMA and interrupt status) in the
//           DWC_ssi macrocell.
//
//        1: Decodes the reg_wr_addr input to generate select signals
//           for each SW register in the macrocell.
//
//        2: Update SW register values from the reg_wr_data input when
//           the register is selected and the wr_en input is active.
//
//        3: Outputs the selected registers data onto the reg_rd_data
//           output bus.  The reg_rd_data output is zero padded when the
//           select register is less than 32-bits wide.
//
//        4: Performs synchronisation on inputs that are generated in
//           the ssi_clk domain.
//
//        5: Outputs write enable and register select signals for the
//           DMA and interrupt status SW-registers.
//
//        6: Generates the start_xfer signal used to initiate serial
//           transfers in the DWC_ssi master.
//
//        7: Generates the ssi_sleep signal used to inform the system
//           clock generator module that it is safe to remove the
//           ssi_clock from the macrocell.
//
// -------------------------------------------------------------------

`include "DWC_ssi_all_includes.vh"

// -----------------------------------------------------------
// -- Register bit Width macros
// -----------------------------------------------------------

`define   CTRLR1_RS               16
`define   BAUDR_RS                16
`define   SR_RS                   6 + (`SSIC_IS_MASTER != 0)
`define   INTC_RS                 1
`define   DMACR_RS                2
`define   IDR_RS                  32
`define   VIDR_RS                 32
`define   DR_RS                   `SSIC_MAX_XFER_SIZE
`define   SSIENR_RS               1
`define   RX_SAMPLE_RS            8
`define   TXD_DRIVE_RS            8
`define   SPI_MD_RS               16
`define   XIP_INST_RS             16
`define   AFSMTOCR_RS             16


// ---------------------------------------------------------
// -- Register module for DWC_ssi macrocell
// ---------------------------------------------------------
module DWC_ssi_regfile
  (
   //------------------------------------------------------------
   //   Clock and Reset
   //------------------------------------------------------------
   input                                 clk,                  // AHB Clock
   input                                 resetn,               // AHB Reset

   //------------------------------------------------------------
   // AHB Bus Interface
   //------------------------------------------------------------

   // Write Interface
   input  [`SSIC_ADDR_SLICE_LHS-1:0]     reg_wr_addr,          // Write Address
   input  [`SSIC_ADDR_SLICE_LHS-1:0]     reg_addr_slice,       // Write address slice (combinational)
   input                                 ahb_sel,
   input                                 wr_en,                // Write Request Signal
   input  [3:0]                          byte_en,              // Write Byte Enable
   input                                 reg_wr_data_vld,      // Write data valid
   input  [`SSIC_REG_DATA_WIDTH-1:0]     reg_wr_data,          // AHB Write data
   output                                reg_wr_ack,           // AHB Write Ackowledgement
   output [1:0]                          reg_wr_err_type,      // AHB Write error type

   // Read Interface
   input                                 rd_en,                // Read Request
   input  [`SSIC_ADDR_SLICE_LHS-1:0]     reg_rd_addr,          // Read Address
   output reg [`SSIC_REG_DATA_WIDTH-1:0] reg_rd_data,          // Read Data
   output                                reg_rd_ack,           // Read Ackowledgement
   output [1:0]                          reg_rd_err_type,      // Read Error Type



   //------------------------------------------------------------
   // FSM interface
   //------------------------------------------------------------
   input                                 fsm_sleep,            // FSM Sleep status
   input                                 fsm_busy,             // FSM busy status
   input                                 fsm_multi_mst,        // Multi-master contention input
   input                                 mst_contention,       // Master contention status
   output                                multi_mst_sync,       // mult-master contention status
   output reg                            start_xfer,           // Start Transfer to start Master FSM
   output reg                            baud2,                // Baud rate = 2 signal
   output reg [`BAUDR_RS-1:0]            baudr,                // Baud rate register value
   output reg                            sclk_active,          // sclk_out active edge
   output [`CTRLR0_RS-1:0]               ctrlr0,               // CTRLR0 Register Value
   output [`SPI_CTRLR0_RS-1:0]           spi_ctrlr0,           // SPI control register value
   output reg  [6:0]                     spi_ctrlr1,           // SPI control -1 register value
   output  [`SSIC_NUM_SLAVES-1:0]        ser,                  // Slave enable register
   output  [16:0]                        ndf,                  // Number of data frames register
   output                                set0_imr5,
   output                                set1_imr5,
   //------------------------------------------------------------
   // FIFO interface
   //------------------------------------------------------------
   input  [`SSIC_MAX_XFER_SIZE-1:0]      rx_pop_data,          // RX pop data
   output reg [`SSIC_MAX_XFER_SIZE-1:0]  tx_push_data,         // Tx Push Data
   output                                rx_pop,               // RX pop signal
   output reg                            tx_push,              // TX push signal
   input                                 tx_pop,               // TX POP signal
   input [`TX_ABW:0]                     tx_fifo_wc,           // Tx FIFO word count
   input [`RX_ABW:0]                     rx_fifo_wc,           // Rx FIFO word count
   output                                fifo_rst_n,           // FIFO soft reset
   input                                 tx_full,              // Tx FIFO full status
   input                                 tx_empty,             // Tx FIFO empty status
   input                                 rx_full,              // Rx FIFO full status
   input                                 rx_empty,             // Rx FIFO empty status

   //------------------------------------------------------------
   // DMA interface
   //------------------------------------------------------------
   input   [`DMACR_RS-1:0]               dmacr,                // DMA control register
   input   [`TX_ABW-1:0]                 dmatdlr,              // DMA transmit data level register
   input   [`RX_ABW-1:0]                 dmardlr,              // DMA recieve data level register
   output                                dmacr_we,             // DMA control write enable
   output                                dmatdlr_we,           // DMA transmit data level Write enable
   output                                dmardlr_we,           // DMA recieve data level write enable
   output  reg [`TX_ABW:0]               txflr,                // TX FIFO level Register
   output  reg [`RX_ABW:0]               rxflr,                // RX FIFO level register
   //------------------------------------------------------------
   // System Control interface
   //------------------------------------------------------------
   output                                ssi_sleep,            // SSI sleep signal
   //------------------------------------------------------------
   // Shift Register Interface
   //------------------------------------------------------------
   output     [`RX_SAMPLE_RS-1:0]        rx_sample_dly,        // Rx Sample delay value
   output  reg                           ssienr,               // SSI Enable Register
   output  reg                           spi_dyn_ws,           // SPI dynamic wait state enable                
   output  [`MWCR_RS-1:0]                mwcr,                 // Micro Write Control Register
   output  reg [`TX_ABW-1:0]             txftlr,               // Transmit FIFO threshold level register
   output  reg [`TXFTHR_W-1:0]           txfthr,
   output  reg [`RX_ABW-1:0]             rxftlr,               // Recieve FIFO threshold level register
   //------------------------------------------------------------
   // Interrupt interface
   //------------------------------------------------------------
   input   [`INT_RS-1:0]                 isr,                 // Interrupt status register
   input   [`INT_RS-1:0]                 risr,                // Raw interrupt status register
   output                                rdec_icr_en,              // Interrupt clear enable register
   output                                rdec_txoicr_en,           // Transmit overflow interrupt clear
   output                                rdec_rxoicr_en,           // Recieve FIFO overflow interrupt clear
   output                                rdec_spitecr_en,        // SPI transmit error clear 
   output                                rdec_rxuicr_en,           // Recieve FIFO underflow clear
   output                                rdec_msticr_en,           // Master contention clear
   output                                tx_overflow,
   output  [`INT_RS-1:0]                 imr                  // Interrupt Mask Register
   );

  // ------------------------------------------------------
  // -- Local parameters declaration
  // ------------------------------------------------------
  //spyglass disable_block ParamWidthMismatch-ML
  //SMD: Parameter width does not match
  //SJ: Warning can be ignored
  //spyglass disable_block W164a 
  //SMD: LHS is less than RHS in assignment 
  //SJ: This operation is safe
  //spyglass disable_block W164b 
  //SMD: LHS is greater than RHS in assignment 
  //SJ: This operation is safe
  
