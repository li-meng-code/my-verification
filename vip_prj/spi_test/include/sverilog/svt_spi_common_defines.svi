
`ifndef GUARD_SVT_SPI_COMMON_DEFINES_SVI
`define GUARD_SVT_SPI_COMMON_DEFINES_SVI

`define svt_spi_print_int(STRING,VALUE,BIT_COUNT,RADIX)\
  `ifdef SVT_UVM_TECHNOLOGY \
  `ifndef SVT_UVM_1800_2_2017_OR_HIGHER \
    printer.print_int(STRING,VALUE,BIT_COUNT,UVM_``RADIX);\
  `else \
    printer.print_field_int(STRING,VALUE,BIT_COUNT,UVM_``RADIX);\
  `endif \
  `elsif SVT_OVM_TECHNOLOGY \
    printer.print_field(STRING,VALUE,BIT_COUNT,OVM_``RADIX);\
  `else \
   begin \
    string radix; \
    radix = "RADIX"; \
    if(radix == "HEX") \
     `print_int(STRING,VALUE,BIT_COUNT,0h) \
    else \
     `print_int(STRING,VALUE,BIT_COUNT,0d) \
   end \
  `endif

`define svt_spi_print_real(STRING,VALUE)\
  `ifdef SVT_OVM_TECHNOLOGY \
    printer.print_field_real(STRING,VALUE); \
  `elsif SVT_UVM_TECHNOLOGY \
    printer.print_real(STRING,VALUE); \
  `endif

/** Indicates SPI Standard mode feature */
`define SVT_SPI_STD 0

/** @cond PRIVATE */
/** Indicates EMPSPI mode */
`define SVT_SPI_EMPSPI 1
/** @endcond */

/** Indicates SPI Multilane generic mode */
`define SVT_SPI_MULTILANE 2

/** Indicates Part specific SPI Flash Mode */
`define SVT_SPI_FLASH 3

/** Indicates SAFE SPI Mode */
`define SVT_SPI_SAFE 4

/** Indicates SPI Phase and polarity. Here CPHA = 0 , CPOL = 0 */
`define SVT_SPI_MODE_0 0

/** Indicates SPI Phase and polarity. Here CPHA = 1 , CPOL = 0 */
`define SVT_SPI_MODE_1 1

/** Indicates SPI Phase and polarity. Here CPHA = 0 , CPOL = 1 */
`define SVT_SPI_MODE_2 2

/** Indicates SPI Phase and polarity. Here CPHA = 1 , CPOL = 1 */
`define SVT_SPI_MODE_3 3

/** Indicates SPI LITTLE Endian Format */
`define SVT_SPI_LITTLE_ENDIAN 0

/** Indicates SPI BIG ENDIAN Format */
`define SVT_SPI_BIG_ENDIAN 1

/** Indicates SPI 8 BIT WORD Format */
`define SVT_SPI_8B_WORD 0

/** Indicates SPI 16 BIT WORD Format */
`define SVT_SPI_16B_WORD 1

/** Indicates SPI 32 BIT WORD Format */
`define SVT_SPI_32B_WORD 2

/** @cond PRIVATE */
/** Indicates EMPSPI Negotiation Request */
`define SVT_SPI_NEGOTIATION_REQUEST 0

/** Indicates EMPSPI Negotiation Response */
`define SVT_SPI_NEGOTIATION_RESPONSE 1

/** Indicates EMPSPI Sleep Threshold Request */
`define SVT_SPI_SLEEP_THRESHOLD_REQUEST 2

/** Indicates EMPSPI Sleep Threshold Response */
`define SVT_SPI_SLEEP_THRESHOLD_RESPONSE 3
/** @endcond */

/** Indicates Bluetooth HCI Read Messages */
`define SVT_SPI_BLUETOOTH_HCI_READ 4

/** Indicates Bluetooth HCI Write Messages */
`define SVT_SPI_BLUETOOTH_HCI_WRITE 5

/** Indicates SPI feature by Motorola. */
`define SVT_SPI_FEATURE_OFFICIAL 0

/** Indicates SSP feature by Texas. */
`define SVT_SPI_FEATURE_SSP 1

/** Indicates MicroWire feature by National Semiconductors. */
`define SVT_SPI_FEATURE_UWIRE 2

/** Indicates Instruction Frame width */
`ifndef SVT_SPI_MAX_INST_FRAME_WIDTH
`define SVT_SPI_MAX_INST_FRAME_WIDTH 32
`endif

/** Indicates Address Frame width */
`ifndef SVT_SPI_MAX_ADDR_FRAME_WIDTH
`define SVT_SPI_MAX_ADDR_FRAME_WIDTH 32
`endif

/** Indicates Wrap mode bit width */
`ifndef SVT_SPI_MAX_WRAP_CFG_BIT_WIDTH
`define SVT_SPI_MAX_WRAP_CFG_BIT_WIDTH 8 
`endif

/** Indicates Plane select bit width */
`ifndef SVT_SPI_MAX_PLANE_SELECT_CFG_BIT_WIDTH
`define SVT_SPI_MAX_PLANE_SELECT_CFG_BIT_WIDTH 32 
`endif

/** Indicates ECC bit width */
`ifndef SVT_SPI_MAX_ECC_BIT_WIDTH
`define SVT_SPI_MAX_ECC_BIT_WIDTH 32 
`endif

/** Indicates Attribute bit width */
`ifndef SVT_SPI_ATTRIBUTE_BIT_WIDTH
`define SVT_SPI_ATTRIBUTE_BIT_WIDTH 8 
`endif

/** Indicates Maximum Partial Program Partitions Count */
`ifndef SVT_SPI_MAX_PAGE_PROGRAM_PARTITION
`define SVT_SPI_MAX_PAGE_PROGRAM_PARTITION 32
`endif

/** Indicates Maximum SAFE SPI frame Width */
`ifndef SVT_SPI_SAFE_MAX_FRAME_WIDTH
`define SVT_SPI_SAFE_MAX_FRAME_WIDTH 32
`endif

/** Indicates Maximum Number of SCLK PAUSE that can be inserted in a transaction */
`ifndef SVT_SPI_MAX_PAUSE_COUNT
`define SVT_SPI_MAX_PAUSE_COUNT 5
`endif

/** Indicates Maximum Duration for a SCLK PAUSE */
`ifndef SVT_SPI_MAX_PAUSE_DURATION
`define SVT_SPI_MAX_PAUSE_DURATION 10
`endif

/** Operation Mode set to Run Mode */
`define SVT_SPI_RUN_MODE  0

/** Operation Mode set to Wait Mode */
`define SVT_SPI_WAIT_MODE 1      

/** Operation Mode set to Stop Mode */
`define SVT_SPI_STOP_MODE 2 

/** Maximum value of leading time before the first sclk edge */ 
`define SVT_SPI_MAX_LEADING_TIME 10

/** Maximum value of trailing time after the last sclk edge */ 
`define SVT_SPI_MAX_TRAILING_TIME 10

/**  IDLE Time in between two Transfer */
`define SVT_SPI_MAX_IDLE_TIME_BETWEEN_TRANSFER 5

/** 
 * Maximum length of Data Array to be transfered.<br/>
 * This works as upper limit when randomizing the length of Data phase for <br/>
 * SPI_STD,SPI_MULTILANE and SPI FLASH commands(except program and OTP) 
 */
`ifndef SVT_SPI_MAX_DATA_TRANSFER
`define SVT_SPI_MAX_DATA_TRANSFER 10
`endif

/**
 * Maximum OTP bytes transferred during READ_OTP_ARRAY/PROGRAM_OTP_ARRAY <br/>
 * This macro is used by SPI Flash Controller/Master agent as upper limit <br/>
 * when randomizing the length of Data phase.
 */
`ifndef SVT_SPI_MAX_OTP_BYTES_TRANSFER
`define SVT_SPI_MAX_OTP_BYTES_TRANSFER 100
`endif

/**
 * Maximum bytes transferred during PROGRAM command <br/>
 * This macro is used by SPI Flash Controller/Master agent as upper limit <br/>
 * when randomizing the length of Data phase.
 */
`ifndef SVT_SPI_MAX_PROGRAM_BYTES_TRANSFER
`define SVT_SPI_MAX_PROGRAM_BYTES_TRANSFER 256
`endif

/**
 * Maximum bytes transferred during TUNING DATA PATTERN command <br/>
 * This macro is used by SPI Flash Controller/Master agent as upper limit <br/>
 * when randomizing the length of Data phase for thus command.
 */
`ifndef SVT_SPI_MAX_TUNING_DATA_PATTERN_BYTES_TRANSFER
`define SVT_SPI_MAX_TUNING_DATA_PATTERN_BYTES_TRANSFER 64
`endif

/** Maximum clock delay for transmit_delay*/
`define SVT_SPI_MAX_TRANSMIT_DELAY 10 

/** Maximum Time from master assert ss_n to slave assert SPI_INT (DirectWrite) */
`define SVT_SPI_MAX_ASSERT_SPI_SSN_TO_SPI_INT_TIME 5

/** Maximum Time from slave assert SPI_INT to master assert ss_n (DirectRead) */
`define SVT_SPI_MAX_ASSERT_SPI_INT_TO_SPI_SSN 5

`define SVT_SPI_MIN_TIMEOUT_THRESHOLD 10 
`define SVT_SPI_MAX_TIMEOUT_THRESHOLD 100

/** Time from last sample on MOSI/MISO to slave deassert SPI_INT */ 
`define SVT_SPI_MAX_LAST_SAMPLE_TO_SPI_INT_DEASSERT 5

/** @cond PRIVATE */
/** Maximum Internal Time taken by Slave Agent to assert the SPI_INT on SPI Bus for DIRECT READ */
`define SVT_SPI_MAX_EMPSPI_SPI_INT_TRANSMIT_DELAY 8 

`define SVT_SPI_EMPSPI_DEASSERT_SPI_INT_IN_MIDDLE_OF_BYTE_TRANSFER 0
`define SVT_SPI_EMPSPI_INVALID_HEADER_BYTE 1
`define SVT_SPI_EMPSPI_INVALID_PAYLOAD_LENGTH 2
`define SVT_SPI_EMPSPI_NO_OP_ERROR 3

`define SVT_SPI_FLASH_DEASSERT_SSN_IN_MIDDLE_OF_TRANSMISSION 0
`define SVT_SPI_FLASH_SCLK_DUTY_CYCLE 1
`define SVT_SPI_FLASH_NO_OP_ERROR 2
/** @endcond */

`define SVT_SPI_ACTIVE_LOW_POLARITY  0
`define SVT_SPI_ACTIVE_HIGH_POLARITY 1

