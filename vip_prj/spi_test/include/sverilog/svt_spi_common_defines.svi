/** SPI Flash Protocol mode */
`define SVT_SPI_EXTENDED_SPI 3'b011
`define SVT_DUAL_IO          3'b010   
`define SVT_QUAD_IO          3'b001  
`define SVT_OCTAL_IO_STR     3'b100  
`define SVT_OCTAL_IO_DTR     3'b101  
`define SVT_UNDEF_PROTOCOL   3'b000  

/** SPI Flash MODE Register Operation */
`define SVT_SPI_BYTE_OPERATION       2'b00
`define SVT_SPI_PAGE_OPERATION       2'b10   
`define SVT_SPI_SEQUENTIAL_OPERATION 2'b01  

/** Maximum duration for HOLD assert */
`define SVT_SPI_MAX_HOLD_ASSERT_DELAY 10

/** Indicates Non-Sequential transfer state for MicroWire. */
`define SVT_SPI_UWIRE_NON_SEQUENTIAL 0

/** Indicates Sequential transfer state for MicroWire. */
`define SVT_SPI_UWIRE_SEQUENTIAL 1

/** Indicates Maximum duration taken by Slave agent to assert Ready during Handshaking in Micowire mode. */
`define SVT_SPI_UWIRE_MAX_BUSY_TIMER 100

/** 
 * Maximum length of Control Word Array to be transfered.<br/>
 * This works as upper limit when randomizing the length of Control Word for SPI feature set to Microwire mode. 
 */
`ifndef SVT_SPI_UWIRE_MAX_CONTROL_WORD_TRANSFER
`define SVT_SPI_UWIRE_MAX_CONTROL_WORD_TRANSFER 50
`endif

/**
 * Indicates the maximum width of register field for xSPI generic registers
 */
`ifndef SVT_SPI_xSPI_MAX_REG_FIELD_WIDTH
`define SVT_SPI_xSPI_MAX_REG_FIELD_WIDTH 32
`endif

`protect
/** @cond PRIVATE */

/**
 * Macro used to by `SVT_DATA_TYPE::allocate_pattern methods to add new BITVEC pattern_data instances to the allocated pattern.
 * Argument: elemname Provides the name for the pattern_data. The type of this argument is STRING.
 * Argument: methodsflag Indicates which common data class operations are to be supported automatically for this field.
 * Argument: fldwidth Indicates field bit width used by common data class operations.
 * The below SVT Macro has been enhanced to receive string(elemname) and field width(fldwidth) as an argument.
 */
`ifndef SVT_SPI_DATA_UTIL_ALLOC_PATTERN_ELEM_BITVEC 
`define SVT_SPI_DATA_UTIL_ALLOC_PATTERN_ELEM_BITVEC(elemname,methodsflag,fldwidth) \
  add_pattern_prop(allocate_pattern, allocate_pattern_owner, elemname, svt_pattern_data::BITVEC, methodsflag, fldwidth);
`endif

/** @endcond */
`endprotect

`endif // GUARD_SVT_SPI_COMMON_DEFINES_SVI

