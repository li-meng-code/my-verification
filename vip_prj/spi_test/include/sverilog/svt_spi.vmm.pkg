`ifndef GUARD_SVT_SPI_VMM_PKG
`define GUARD_SVT_SPI_VMM_PKG

`ifdef DESIGNWARE_INCDIR
  `define SVT_SPI_LOADER_FILE `"`DESIGNWARE_INCDIR/vip/svt/common/latest/sverilog/include/svt_bootloader.svi`"
  `include `SVT_SPI_LOADER_FILE 
  `include `SVT_SOURCE_MAP_LIB_INCLUDE_PKG(V-2023.12,svt_mem.vmm)
`else
  `include "svt_loader_util.svi"
  `include "svt_mem.vmm.pkg"
`endif

`define SVT_SPI_PKG_LOAD
`include "svt_spi_if.svi"
`include "svt_spi_empspi_if.svi"

package svt_spi_vmm_pkg;
  import `SVT_VMM_PKG::*;
  import svt_vmm_pkg::*;
  import svt_mem_vmm_pkg::*;

`ifndef __SVDOC__
  typedef virtual svt_spi_if svt_spi_vif; 
  typedef virtual svt_spi_empspi_if svt_spi_empspi_vif; 
`endif

  `include `SVT_SOURCE_MAP_AGENT_INCLUDE_SVI(spi_svt,spi_group_svt,V-2023.12,svt_spi_group_source.vmm)

endpackage

`endif // GUARD_SVT_SPI_VMM_PKG
