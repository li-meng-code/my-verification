`ifndef GUARD_SVT_SPI_SYS_IF_SVI
`define GUARD_SVT_SPI_SYS_IF_SVI

/** @cond PRIVATE */
`include "svt_spi_if.svi"
`include "svt_spi_defines.svi"
/** @endcond */

/**
  @grouphdr spi_if_spi_common SPI Interface common attributes.
  This group contains attributes which are common across SPI variants.
*/

/**
  @grouphdr spi_if_spi_bus SPI-Bus(Motorola, Microwire, SSP) attributes.
  This group contains attributes which are relevant to SPI-Bus.
*/

/**
  @grouphdr spi_if_flash SPI Flash attributes
  This group contains attributes which are relevant to SPI Flash.
 */


/**
 * <b>General description:</b><p>
 * SPI VIP provides the SystemVerilog interface which can be used to connect
 * the SPI-Bus to the DUT. A top level interface svt_spi_sys_if is defined. The top
 * level interface contains an array of master VIP & slave VIP interfaces.DUT
 * signals must be connected to System Interface signals.
 * By default, 8 master and 8 slave interfaces are defined in the top level interface.
 * Currently, the maximum master and slave interfaces supported is 8. The
 * number of master and slave interfaces in top level interface can be
 * controlled using macros SVT_SPI_MAX_NUM_MASTERS_{0..8} and
 * SVT_SPI_MAX_NUM_SLAVES_{0..8} respectively. For example, if you want to
 * use 2 master interfaces and 6 slave interfaces, you can define following
 * macros when compiling the VIP:
 * <li> SVT_SPI_MAX_NUM_MASTERS_2<br>
 * <li> SVT_SPI_MAX_NUM_SLAVES_6<br>
  
 */ 

interface svt_spi_sys_if ();

  /** 
   * @groupname spi_if_spi_common
   * In Master Mode, SystemClock is required along with configuration parameters sppr and spr to generate the sclk for slave device.
   * In Slave Mode, SystemClock is used to implement the timers inside Slave,if applicable.
   */
  logic SystemClock;
  
  /**
   * @groupname spi_if_spi_common
   * Active high Reset signal.
   */ 
  logic SystemReset;

  /**
   * @groupname spi_if_flash
   * SPI Flash Device core power supply. <br/>
   * This input port is valid only for SPI Flash Mode.<br/>
   * This must be driven with Logic High to enable the Device functioning.
   */ 
  wire Vcc;
  
  /**
   * @groupname spi_if_flash
   * Ground: Reference for the VCC supply voltage. <br/>
   * This input port is valid only for SPI Flash Mode.<br/>
   */
  wire Vss;

  /**
   * @groupname spi_if_spi_common
   * Serial Clock generated by Master: This pin is used to output the clock with respect to which the <br/>
   * SPI transfers data or receive clock in case of Slave 
   */
  wire sclk;

  /**
   * @groupname spi_if_spi_bus
   * Master In - Slave Out: This pin is used to transmit data out of the SPI module when it is configured<br/> 
   * as a Slave and receive data when it is configured as Master 
   */
  wire [(`SVT_SPI_IO_WIDTH-1):0] miso;

  /**
   * @groupname spi_if_spi_bus
   * Master Out - slave In: This pin is used to transmit data out of the SPI module when it is configured<br/> 
   * as a Master and receive data when it is configured as Slave 
   */
  wire [(`SVT_SPI_IO_WIDTH-1):0] mosi;

  /**
   * @groupname spi_if_spi_common
   * Slave Select: This pin is used to output the select signal from the SPI module to another peripheral <br/> 
   * with which a data transfer is to take place when its configured as a Master and its used as an input to <br/> 
   * receive the slave select signal when the SPI is configured as Slave.  <br/> 
   * Index of ss_n bit vector monitored by Slave device is controlled through configuration field svt_spi_configuration::slave_id.<br/>
   * By Default, This Pin is active low, But Polarity can be controlled through configuration field svt_spi_configuration::cs_polarity. </a>  <br/>
   */
  wire [`SVT_SPI_MAX_NUM_SLAVES-1:0] ss_n;
  
  /**
   * Slave Ready Signal: This port is used by Slave to indicate whether it is ready to Transmit/Receive further data. <br/>
   * Upon detecting not ready status, Master stops the SCLK on SPI Bus till slave_rdy is asserted. <br/>
   * Index of slave_rdy signal is Device specific and is controlled through configuration field svt_spi_configuration::slave_id.<br/>
   * This feature is supported for SPI Bus (Motorola specification) only. <br/>
   * This pin is active when configuration bit svt_spi_configuration::enable_slave_rdy_feature is set. <br/>
   * By Default, This Pin is active low, But Polarity can be controlled through configuration field svt_spi_configuration::slave_rdy_polarity. </a>  
   */
  wire [(`SVT_SPI_MAX_NUM_SLAVES-1):0] slave_rdy;
  
  //----------------------------------------------------------------------------
  // SPI Flash Ports 
  // ---------------------------------------------------------------------------
  
  /**
   * @groupname spi_if_flash
   * This bit carries command codes, addresses, and the data to be programmed. <br/> 
   * In EXTENDED_SPI, This bit Transfers data serially into the device <br/> 
   * In DUAL_IO, dq0 always acts as an input/output. <br/> 
   * In QUAD_IO, dq0 always acts as an input/output, with the exception of the PROGRAM or ERASE <br/> 
   * cycle performed with VPP. The device temporarily enters the extended SPI protocol and then returns
   * to QIO-SPI as soon as VPP goes LOW.
   */
  wire dq0;

  /**
   * @groupname spi_if_flash
   * In EXTENDED_SPI, this bit transfer data serially out of device. <br/> 
   * In DUAL_IO, dq1 always acts as an input/output. <br/> 
   * In QUAD_IO, dq1 always acts as an input/output, with the exception of the PROGRAM or ERASE
   * cycle performed with the enhanced program supply voltage (VPP). <br/> 
   * In this case, device temporarily enters the extended SPI protocol and then returns to QUAD_IO as soon as VPP goes LOW.
   */
  wire dq1;

  /**
   * @groupname spi_if_flash
   * In QUAD_IO mode or in EXTENDED_SPI mode using QUAD FAST READ commands, the
   * signal functions as dq2, providing input/output.
   */
  wire dq2;

  /**
   * @groupname spi_if_flash
   * In QUAD_IO mode or in EXTENDED_SPI mode using quad FAST READ commands, the
   * signal functions as dq3, providing input/output. <br/> 
   * HOLD# is disabled and RESET# is disabled if the device is selected.
   */
  wire dq3;

  /**
   * @groupname spi_if_flash
   * These ports act as input/output when configured for Octal Mode.
   */
  wire dq4;
  wire dq5;
  wire dq6;
  wire dq7;
  /**
   * @groupname spi_if_flash
   * These ports act as input/output when configured for x16 Mode.
   */
  wire dq8;
  wire dq9;
  wire dq10;
  wire dq11;
  wire dq12;
  wire dq13;
  wire dq14;
  wire dq15;
  
  /**
   * @groupname spi_if_flash
   * The pin(Hardware Store Busy) is valid for Cypress device in SPI Flash mode. <br/>
   * It can be left unconnected for other configurations. <br/>
   * When configure for Slave Mode :  <br/>
   * Output: Indicates busy status of Flash Slave Device when LOW. <br/>
   * Input: Hardware STORE implemented by pulling this pin LOW externally. <br/>
   * Index of hsb_n signal is Device specific and is controlled through configuration field svt_spi_configuration::slave_id.<br/>
   * When configure for Master Mode :  <br/>
   * Output: Hardware STORE implemented by pulling this pin LOW.<br/>
   * Input: To Sample the busy status of Flash Slave Device. <br/>
   */
  wire [(`SVT_SPI_MAX_NUM_SLAVES-1):0] hsb_n;

  /**
   * @groupname spi_if_flash
   * This pin is valid for Flash mode devices with Read Data strobe/Write Data Mask feature. <br/>
   * It can be left unconnected for other configurations. <br/>
   * For Read operation, it is driven by Slave for Octal Configuration indicating valid data. <br/>
   * For Write operation, it may act as Input for selected Slave flash part numbers
   */ 
  wire [`SVT_SPI_MAX_DQS_WIDTH-1:0] dqs;

  /**
   * @groupname spi_if_flash
   * This is dedicated vpp pin supported by few Micron NOR flash device family like MT35X. <br/>
   * By default this pin is disabled i.e vpp signal is multiplex with the mosi pins. <br/>
   * Index of vpp signal is Device specific and is controlled through configuration field svt_spi_configuration::slave_id.<br/>
   * This signal is enabled through mode register configuration variable enable_dedicated_vpp_port. <br/>
   * When enabled for operation, This port provides additional VPP power supply for selected device <br/>
   * to speed up internal operations. <br/>
   */
  wire [(`SVT_SPI_MAX_NUM_SLAVES-1):0] vpp; 

  /**
   * @groupname spi_if_flash
   * This is a dedicated Hold pin supported by few STM NOR Flash device family like M95. <br/>
   * By default this pin is disabled i.e hold signal is multiplex with the mosi pins. <br/>
   * This signal is enabled through mode register configuration variable enable_dedicated_hold_port. <br/>
   * It can be left unconnected by other devices. <br/>
   */
  wire hold_n; 

  /**
   * @groupname spi_if_flash
   * This is a dedicated W# pin supported by few STM NOR Flash device family like M95. <br/>
   * By default this pin is disabled i.e hold signal is multiplex with the mosi pins. <br/>
   * This signal is enabled through mode register configuration variable enable_dedicated_write_protect_port. <br/>
   * It can be left unconnected by other devices. <br/>
   */
  wire write_protect_n; 

  /**
   * @groupname spi_if_flash
   * The pin(ECC Correction SignalStore Busy) is valid for Macronix(MX25UM and MX25Lm) device in SPI Flash Slave mode. <br/>
   * It can be left unconnected for other configurations. <br/>
   * This pin is a real time hardware signal to feedback the ECC correction status. This is designed as <br/>
   * an open drain structure. In normal situation, the #ecs_n is kept on Hi-Z state. <br/> 
   * Once error correction begins, the #ecs_n pin will pull low during the whole ECC chunk unit <br/>
   * The pin is default as going low when 2-bit error detection is enabled and double program detected. <br/> 
   * However, user can select the different option Configuration Register 2
   */
  wire ecs_n;

  /**
   * The pin(INT# System Interrupt ) is valid for Spansion(S28HS Octal) device in SPI Flash Slave mode. <br/> 
   * When LOW, the device indicates that an internal event has occurred.  <br/>
   * This signal is intended to be used as a system level interrupt for the device to indicate that an onchip  <br/>
   * event has occurred.  <br/>
   * However, user can select the different option INT# Configuration Register  <br/>
   * Currently this is tested with Single Slave Mode Only.
   */
  wire int_n;

  /**
   * @groupname spi_if_flash
   * Parallel Mode Input/Output pin: For Master, This pin is used to transmit program data out of the SPI module and receive data for read & read id commands. <br/> 
   * and For Slave, This pin is used to transmit data out for Read and Read ID commands and receive data for Program Command. <br/> 
   */
  wire [(`SVT_SPI_PIO_WIDTH-1):0] parallel_io;

/** @cond PRIVATE */

  /** Signals used for internal connections Only */
  wire [(`SVT_SPI_MAX_NUM_MASTERS-1):0] master_collective_slave_select;
  wire [(`SVT_SPI_MAX_NUM_MASTERS-1):0] slave_select_input_bit_vector;

  /**Specifies the protocol mode */
  int protocol_mode = `SVT_SPI_STD;  
  
  /**Specifies the selected Chip select polarity */
  int cs_polarity = `SVT_SPI_ACTIVE_LOW_POLARITY;

  /**Specifies Valid count of Selected VIP agent in Master mode.*/
  int num_vip_masters = `SVT_SPI_MAX_NUM_MASTERS;

  /**Specifies Valid count of Selected VIP agent in Slave mode.*/
  int num_vip_slaves = `SVT_SPI_MAX_NUM_SLAVES;

  /** 
   * Specifies valid active VIP master interface. Index is selected based on
   * configured master_id.
   */
  bit [(`SVT_SPI_MAX_NUM_MASTERS-1):0] enable_master_if;

  /** 
   * Specifies valid active VIP master interface. Index is selected based on
   * configured master_id.
   */
  bit [(`SVT_SPI_MAX_NUM_SLAVES-1):0] enable_slave_if;
/** @endcond */

  // Number of SPI master instances.
  svt_spi_if master_if [`SVT_SPI_MAX_NUM_MASTERS] (.bus_clk(SystemClock), .reset(SystemReset));

  // Number of SPI slave instances.
  svt_spi_if slave_if [`SVT_SPI_MAX_NUM_SLAVES] (.bus_clk(SystemClock), .reset(SystemReset));

  //-----------------------------------------------------------------------
  // Accessor method to obtain a master interface
  //-----------------------------------------------------------------------
`ifndef __SVDOC__
  function svt_spi_vif get_master_if(int idx);
    if( idx<num_vip_masters && idx>=0 ) begin
       case(idx) 
`ifdef SVT_SPI_VALID_MASTER_IDX_0
         0: get_master_if = master_if[0];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_1
         1: get_master_if = master_if[1];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_2
         2: get_master_if = master_if[2];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_3
         3: get_master_if = master_if[3];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_4
         4: get_master_if = master_if[4];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_5
         5: get_master_if = master_if[5];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_6
         6: get_master_if = master_if[6];
`endif         
`ifdef SVT_SPI_VALID_MASTER_IDX_7
         7: get_master_if = master_if[7];
`endif         
        default: begin
          $display("svt_spi_sys_if::get_master_if(): Master index %0d not supported.", idx);
          $finish;
        end
       endcase
    end  
  endfunction

  //-----------------------------------------------------------------------
  // Accessor method to obtain a slave interface
  //-----------------------------------------------------------------------
  function svt_spi_vif get_slave_if(int idx);
    if( idx<num_vip_slaves && idx>=0 ) begin
       case(idx) 
`ifdef SVT_SPI_VALID_SLAVE_IDX_0
         0: get_slave_if = slave_if[0];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_1
         1: get_slave_if = slave_if[1];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_2
         2: get_slave_if = slave_if[2];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_3
         3: get_slave_if = slave_if[3];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_4
         4: get_slave_if = slave_if[4];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_5
         5: get_slave_if = slave_if[5];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_6
         6: get_slave_if = slave_if[6];
`endif         
`ifdef SVT_SPI_VALID_SLAVE_IDX_7
         7: get_slave_if = slave_if[7];
`endif         
        default: begin
          $display("svt_spi_sys_if::get_slave_if(): Slave index %0d not supported.", idx);
          $finish;
        end
       endcase
     end  
  endfunction

//-----------------------------------------------------------------------
// Active Master/Slave agent connections
//-----------------------------------------------------------------------
genvar m_id;
genvar m_dqs_id;
genvar pio_id;
genvar ss_in_n_connect;

  generate
    for (m_id=0; m_id < `SVT_SPI_MAX_NUM_MASTERS; m_id=m_id+1) begin :MASTER_CONNECT
      assign sclk                         = enable_master_if[m_id] ? master_if[m_id].sclk : 'bz; 

      assign ss_n         = master_if[m_id].ss_n; 

      assign master_collective_slave_select[m_id]  = enable_master_if[m_id] ? ((cs_polarity  == `SVT_SPI_ACTIVE_HIGH_POLARITY)? (|master_if[m_id].ss_n) : (&master_if[m_id].ss_n)) : 'bz;
      assign master_if[m_id].ss_in_n = (cs_polarity  == `SVT_SPI_ACTIVE_HIGH_POLARITY) ? (|slave_select_input_bit_vector) : (&slave_select_input_bit_vector); 

      assign mosi         = (enable_master_if[m_id] && protocol_mode == `SVT_SPI_STD) ? master_if[m_id].mosi : 'z; 

      assign master_if[m_id].miso = (protocol_mode == `SVT_SPI_STD) ? miso : 'z;
      assign master_if[m_id].slave_rdy = (protocol_mode == `SVT_SPI_STD) ? slave_rdy : 'z;
      //Flash mode
      assign Vcc  = (enable_master_if[m_id] && protocol_mode == `SVT_SPI_FLASH) ? master_if[m_id].Vcc : 1'bz;
      assign master_if[m_id].Vss  = (protocol_mode == `SVT_SPI_FLASH) ? Vss : 1'b0;
      assign master_if[m_id].Vcc  = (enable_master_if[m_id] == 1'b0 && protocol_mode == `SVT_SPI_FLASH) ? Vcc : 1'bz;
      for (m_dqs_id=0; m_dqs_id < `SVT_SPI_MAX_DQS_WIDTH; m_dqs_id=m_dqs_id+1) begin :MASTER_DQS_CONNECT
        assign master_if[m_id].dqs[m_dqs_id] = master_if[m_id].dm_oe_n[m_dqs_id] ? dqs[m_dqs_id] : 'bz;
        assign dqs[m_dqs_id] = (enable_master_if[m_id] && protocol_mode == `SVT_SPI_FLASH) ? master_if[m_id].dm_oe_n[m_dqs_id] ? 'bz : master_if[m_id].dqs[m_dqs_id] 
                                                                                           : 'bz;
      end
      assign vpp  = (enable_master_if[m_id] && protocol_mode == `SVT_SPI_FLASH) ? master_if[m_id].vpp : 'hz;
      assign hold_n  = (enable_master_if[m_id] && protocol_mode == `SVT_SPI_FLASH) ? master_if[m_id].vpp : 'bz;
      assign write_protect_n  = (enable_master_if[m_id] && protocol_mode == `SVT_SPI_FLASH) ? master_if[m_id].write_protect_n : 'bz;
      assign master_if[m_id].ecs_n  = (protocol_mode == `SVT_SPI_FLASH) ? ecs_n : 1'bz;
      assign master_if[m_id].int_n  = (protocol_mode == `SVT_SPI_FLASH) ? int_n : 1'bz;

      for(pio_id=0; pio_id < `SVT_SPI_PIO_WIDTH; pio_id=pio_id+1) begin :MASTER_PARALLEL_IO
        assign master_if[m_id].parallel_io[pio_id] = master_if[m_id].parallel_io_oe_n[pio_id] ? parallel_io[pio_id] : 1'bz; 
        assign parallel_io[pio_id] = master_if[m_id].parallel_io_oe_n[pio_id] ? 1'bz : master_if[m_id].parallel_io[pio_id] ; 
      end
    end
  endgenerate  

  generate
    for (ss_in_n_connect=0; ss_in_n_connect < `SVT_SPI_MAX_NUM_MASTERS; ss_in_n_connect=ss_in_n_connect+1) begin : MASTER_SS_IN_N_CONNECT
      // Propagating Idle value if connected Master SS_N is high impedence or unknown value. 
      assign slave_select_input_bit_vector[ss_in_n_connect] = (protocol_mode == `SVT_SPI_STD) ? ((master_collective_slave_select[ss_in_n_connect] === 1'bx || master_collective_slave_select[ss_in_n_connect] === 1'bz) ? ((cs_polarity  == `SVT_SPI_ACTIVE_HIGH_POLARITY) ? 1'b0 : 1'b1) : master_collective_slave_select[ss_in_n_connect]) : 'z;
    end
  endgenerate

genvar s_id;
genvar s_pio_id;
genvar s_dqs_id;
  generate
    for (s_id=0; s_id < `SVT_SPI_MAX_NUM_SLAVES; s_id=s_id+1) begin :SLAVE_CONNECT
      assign miso = enable_slave_if[s_id] ? slave_if[s_id].miso :'hz; 

      assign slave_if[s_id].sclk = sclk; 
      assign slave_if[s_id].ss_n = ss_n; 
      assign slave_rdy = (enable_slave_if[s_id] && protocol_mode == `SVT_SPI_STD) ? slave_if[s_id].slave_rdy : 'bz; 
      assign slave_if[s_id].mosi = (protocol_mode == `SVT_SPI_STD) ? mosi : 'bz; 
      // Flash mode
      assign slave_if[s_id].Vcc  = (protocol_mode == `SVT_SPI_FLASH) ? Vcc : 1'b0;
      assign slave_if[s_id].Vss  = (protocol_mode == `SVT_SPI_FLASH) ? Vss : 1'b0;
      for (s_dqs_id=0; s_dqs_id < `SVT_SPI_MAX_DQS_WIDTH; s_dqs_id=s_dqs_id+1) begin :SLAVE_DQS_CONNECT
        assign dqs[s_dqs_id]  = (enable_slave_if[s_id] && protocol_mode == `SVT_SPI_FLASH && slave_if[s_id].dm_oe_n[s_dqs_id]) ? slave_if[s_id].dqs[s_dqs_id] : 'bz;
        assign slave_if[s_id].dqs[s_dqs_id]  = ((slave_if[s_id].dm_oe_n[s_dqs_id] == 0) && protocol_mode == `SVT_SPI_FLASH) ? dqs[s_dqs_id] : 1'bz;
      end
      assign slave_if[s_id].vpp  = (protocol_mode == `SVT_SPI_FLASH) ? vpp : 1'bz;
      assign slave_if[s_id].hold_n  = (protocol_mode == `SVT_SPI_FLASH) ? hold_n : 1'bz;
      assign slave_if[s_id].write_protect_n  = (protocol_mode == `SVT_SPI_FLASH) ? write_protect_n : 1'bz;
      assign ecs_n  = (enable_slave_if[s_id] && protocol_mode == `SVT_SPI_FLASH) ? slave_if[s_id].ecs_n : 'bz;
      assign int_n  = (enable_slave_if[s_id] && protocol_mode == `SVT_SPI_FLASH) ? slave_if[s_id].int_n : 'bz;

      for(s_pio_id=0; s_pio_id < `SVT_SPI_PIO_WIDTH; s_pio_id=s_pio_id+1) begin : SLAVE_PARALLEL_IO
        assign slave_if[s_id].parallel_io[s_pio_id] = slave_if[s_id].parallel_io_oe_n[s_pio_id] ? parallel_io[s_pio_id] : 1'bz; 
        assign parallel_io[s_pio_id] = slave_if[s_id].parallel_io_oe_n[s_pio_id] ? 1'bz : slave_if[s_id].parallel_io[s_pio_id]; 
      end
    end
  endgenerate 

genvar m_id_connect;
genvar s_id_connect;
 generate
    for (m_id_connect=0; m_id_connect < `SVT_SPI_MAX_NUM_MASTERS; m_id_connect=m_id_connect+1) begin :MASTER_DQ_CONNECT
        assign dq0 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[0] ? 1'bz : master_if[m_id_connect].dq0) : 1'bz;
        assign master_if[m_id_connect].dq0 = master_if[m_id_connect].oe_n[0] ? dq0 : 1'bz;
        assign dq1 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[1] ? 1'bz : master_if[m_id_connect].dq1) : 1'bz;
        assign master_if[m_id_connect].dq1 = master_if[m_id_connect].oe_n[1] ? dq1 : 1'bz;
        assign dq2 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[2] ? 1'bz : master_if[m_id_connect].dq2) : 1'bz;
        assign master_if[m_id_connect].dq2 = master_if[m_id_connect].oe_n[2] ? dq2 : 1'bz;
        assign dq3 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[3] ? 1'bz : master_if[m_id_connect].dq3) : 1'bz;
        assign master_if[m_id_connect].dq3 = master_if[m_id_connect].oe_n[3] ? dq3 : 1'bz;
        assign dq4 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[4] ? 1'bz : master_if[m_id_connect].dq4) : 1'bz;
        assign master_if[m_id_connect].dq4 = master_if[m_id_connect].oe_n[4] ? dq4 : 1'bz;
        assign dq5 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[5] ? 1'bz : master_if[m_id_connect].dq5) : 1'bz;
        assign master_if[m_id_connect].dq5 = master_if[m_id_connect].oe_n[5] ? dq5 : 1'bz;
        assign dq6 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[6] ? 1'bz : master_if[m_id_connect].dq6) : 1'bz;
        assign master_if[m_id_connect].dq6 = master_if[m_id_connect].oe_n[6] ? dq6 : 1'bz;
        assign dq7 = (protocol_mode == `SVT_SPI_FLASH) ? (master_if[m_id_connect].oe_n[7] ? 1'bz : master_if[m_id_connect].dq7) : 1'bz;
