
`ifndef GUARD_SVT_SPI_IF_SVI
`define GUARD_SVT_SPI_IF_SVI

`include "svt_spi_defines.svi"
typedef virtual svt_spi_if svt_spi_vif;

/**
 * This SystemVerilog 'interface' definition declares all of the signals
 * (scoped within an instance of this interface) that are specified by
 * the SPI Protocol Specification as being (potentially) included in
 * a SPI Tx/Rx connection.
 * It requires bus_clk and reset (active high) to be connected in top level
 * testbench. 
 * bus_clk is the reference clock input from testbench.
 * In Master Mode, bus_clk is required along with configuration parameters sppr and spr to generate the sclk for slave device.
 * In Slave Mode, bus_clk is used to implement the timers inside Slave,if applicable.
 * SVT_SPI_IO_WIDTH define determines the width of MOSI/MISO pins.
 * SVT_SPI_PIO_WIDTH define determines the width of PO pins in Parallel Mode.
 * SVT_SPI_MAX_NUM_SLAVES define determines the width for ss_n(slave select)and spi_interrupt port.
 * When SPI Flash mode is selected, SVT_SPI_IO_WIDTH mimimum value is 4.
 */
interface svt_spi_if (
  input logic bus_clk,
  input logic reset
);

  //----------------------------------------------------------------------------
  // SPI Interface Ports 
  // ---------------------------------------------------------------------------
  /**
   * Serial Clock generated by Master: This pin is used to output the clock with respect to which the <br/>
   * SPI transfers data or receive clock in case of Slave 
   */
  wire  sclk;

  /**
   * Master In - Slave Out: This pin is used to transmit data out of the SPI module when it is configured<br/> 
   * as a Slave and receive data when it is configured as Master 
   */
  wire [(`SVT_SPI_IO_WIDTH-1):0] miso;

  /**
   * Master Out - slave In: This pin is used to transmit data out of the SPI module when it is configured<br/> 
   * as a Master and receive data when it is configured as Slave 
   */
  wire [(`SVT_SPI_IO_WIDTH-1):0] mosi;

  /**
   * Slave Select: This pin is used to output the select signal from the SPI module to another peripheral <br/> 
   * with which a data transfer is to take place when its configured as a Master and its used as an input to <br/> 
   * receive the slave select signal when the SPI is configured as Slave  <br/> 
   * By Default, This Pin is active low, But Polarity can be controlled through configuration field svt_spi_configuration::cs_polarity. </a>  <br/>
   */
  wire [(`SVT_SPI_MAX_NUM_SLAVES-1):0] ss_n;

  /**
   * Slave Select Input: This pin is used in Master Mode only to detect SS_N being driven by another Master on SPI System <br/> 
   * This Pin along with Mode Fault is used for detecting Mode Fault failure in Multi-Master Mode.   <br/>
   * This can be tied to constant value or left un-connected in Single Master System. <br/>
   * It is supported for all SPI Bus modes(SPI Motorola,  SSP Texas Instrument & UWIRE National Semiconductors). <br/>
   */
  wire ss_in_n;

  /**
   * Output Enable: This pin depicts the valid output data on each lane for SPI module. <br/>
   * For Master Mode, this depicts valid output data for MOSI lines and <br/>
   * For Slave Mode, this depicts valid output data for MISO lines 
   */
  wire [(`SVT_SPI_IO_WIDTH-1):0] oe_n;

  /**
   * Parallel Mode Input/Output pin: For Master, This pin is used to transmit program data out of the SPI module and receive data for read & read id commands. <br/> 
   * and For Slave, This pin is used to transmit data out for Read and Read ID commands and receive data for Program Command. <br/> 
   */
  wire [(`SVT_SPI_PIO_WIDTH-1):0] parallel_io;

  /**
   * Parallel Mode Output Enable: This pin depicts the valid parallel output data on PO lanes. <br/>
   * For Master Mode, this depicts valid output data for PO lines and <br/>
   * For Slave Mode, this depicts valid output data for PO lines 
   */
  wire [(`SVT_SPI_PIO_WIDTH-1):0] parallel_io_oe_n;

  /**
   * Slave Ready Signal: This port is used by Slave to indicate whether it is ready to Transmit/Receive further data. <br/>
   * Upon detecting not ready status, Master stops the SCLK on SPI Bus till slave_rdy is asserted. <br/>
   * This feature is supported for SPI Bus (Motorola specification) only. <br/>
   * This pin is active when configuration bit svt_spi_configuration::enable_slave_rdy_feature is set. <br/>
   * By Default, This Pin is active low, But Polarity can be controlled through configuration field svt_spi_configuration::slave_rdy_polarity. </a>  
   */
  wire [(`SVT_SPI_MAX_NUM_SLAVES-1):0] slave_rdy;

  /**
   * SPI Interrupt Request: This pin is used by Slave Agent to indicate the SPI Interrupt.<br/>
   * Each Slave Agent has dedicated pin to register the interrupt. 
   */ 
  logic [(`SVT_SPI_MAX_NUM_SLAVES-1):0] spi_interrupt;

  /**
   * SPI Flash Device core power supply. <br/>
   * This input port is valid only for SPI Flash Mode.<br/>
   * This must be driven with Logic High to enable the Device functioning.
   */ 
  wire Vcc;
  
  /**
   * Ground: Reference for the VCC supply voltage. <br/>
   * This input port is valid only for SPI Flash Mode.<br/>
   */
  wire Vss;
  
  /**
   * SPI Flash Device core power supply. <br/>
   * This input port is valid only for SPI Flash Mode.<br/>
   * This must be driven with Logic High to enable the Device functioning.
   */ 
  wire rsto_n;

  /**
   * The pin(Hardware Store Busy) is valid for Cypress device in SPI Flash mode. <br/>
   * It can be left unconnected for other configurations. <br/>
   * When configure for Slave Mode :  <br/>
   * Output: Indicates busy status of Flash Slave Device when LOW. <br/>
   * Input: Hardware STORE implemented by pulling this pin LOW externally. <br/>
   * When configure for Master Mode :  <br/>
   * Output: Hardware STORE implemented by pulling this pin LOW.<br/>
   * Input: To Sample the busy status of Flash Slave Device. <br/>
   */
  wire hsb_n;

  /**
   * This pin is valid for Flash mode devices with Read Data strobe/Write Data Mask feature. <br/>
   * It can be left unconnected for other configurations. <br/>
   * For Read operation, it is driven by Slave for the Configuration indicating valid data. <br/>
   * For Write operation, it may act as Input for selected Slave flash part numbers.
   */ 
  wire [`SVT_SPI_MAX_DQS_WIDTH-1:0] dqs;

  /**
   * This is dedicated vpp pin supported by few Micron NOR flash device family like MT35X. <br/>
   * By default this pin is disabled i.e vpp signal is multiplex with the mosi pins. <br/>
   * This signal is enabled through mode register configuration variable enable_dedicated_vpp_port. <br/>
   * When enabled for operation, This port provides additional VPP power supply for selected device <br/>
   * to speed up internal operations. <br/>
   */
  wire [(`SVT_SPI_MAX_NUM_SLAVES-1):0] vpp; 

  /**
   * This is a dedicated Hold pin supported by few STM NOR Flash device family like M95. <br/>
   * By default this pin is disabled i.e hold signal is multiplex with the mosi pins. <br/>
   * This signal is enabled through mode register configuration variable enable_dedicated_hold_port. <br/>
   * It can be left unconnected by other devices. <br/>
   */
  wire hold_n; 

  /**
   * This is a dedicated W# pin supported by few STM NOR Flash device family like M95. <br/>
   * By default this pin is disabled i.e hold signal is multiplex with the mosi pins. <br/>
   * This signal is enabled through mode register configuration variable enable_dedicated_write_protect_port. <br/>
   * It can be left unconnected by other devices. <br/>
   */
  wire write_protect_n; 

  /**
   * The pin(ECC Correction SignalStore Busy) is valid for Macronix(MX25UM and MX25Lm) device in SPI Flash Slave mode. <br/>
   * It can be left unconnected for other configurations. <br/>
   * This pin is a real time hardware signal to feedback the ECC correction status. This is designed as <br/>
   * an open drain structure. In normal situation, the #ecs_n is kept on Hi-Z state. <br/> 
   * Once error correction begins, the #ecs_n pin will pull low during the whole ECC chunk unit <br/>
   * The pin is default as going low when 2-bit error detection is enabled and double program detected. <br/> 
   * However, user can select the different option Configuration Register 2
   */
  wire ecs_n;

  /**
   * The pin(INT# System Interrupt ) is valid for Spansion(S28HS Octal) device in SPI Flash Slave mode. <br/> 
   * When LOW, the device indicates that an internal event has occurred.  <br/>
   * This signal is intended to be used as a system level interrupt for the device to indicate that an onchip  <br/>
   * event has occurred.  <br/>
   * However, user can select the different option INT# Configuration Register  <br/>
   * Currently this is tested with Single Slave Mode Only.
   */
  wire int_n;

  /** This bit is set after received data byte is transferred into data register. */
  bit spif;

  /** This bit indicates that transmit data register is empty. */
  bit sptef;
  
  /** Mode fault flag, this bit is set if SS pin becomes low, when SPI is master and MODFEN is set. */
  bit modf;

  //----------------------------------------------------------------------------
  // SPI Flash Ports 
  // ---------------------------------------------------------------------------
  
  /**
   * This bit carries command codes, addresses, and the data to be programmed. <br/> 
   * In EXTENDED_SPI, This bit Transfers data serially into the device <br/> 
   * In DUAL_IO, dq0 always acts as an input/output. <br/> 
   * In QUAD_IO, dq0 always acts as an input/output, with the exception of the PROGRAM or ERASE <br/> 
   * cycle performed with VPP. The device temporarily enters the extended SPI protocol and then returns
   * to QIO-SPI as soon as VPP goes LOW.
   */
  wire dq0;

  /**
   * In EXTENDED_SPI, this bit transfer data serially out of device. <br/> 
   * In DUAL_IO, dq1 always acts as an input/output. <br/> 
   * In QUAD_IO, dq1 always acts as an input/output, with the exception of the PROGRAM or ERASE
   * cycle performed with the enhanced program supply voltage (VPP). <br/> 
   * In this case, device temporarily enters the extended SPI protocol and then returns to QUAD_IO as soon as VPP goes LOW.
   */
  wire dq1;

  /**
   * In QUAD_IO mode or in EXTENDED_SPI mode using QUAD FAST READ commands, the
   * signal functions as dq2, providing input/output.
   */
  wire dq2;

  /**
   * In QUAD_IO mode or in EXTENDED_SPI mode using quad FAST READ commands, the
   * signal functions as dq3, providing input/output. <br/> 
   * HOLD# is disabled and RESET# is disabled if the device is selected.
   */
  wire dq3;

  /**
   * These ports act as input/output when configured for Octal Mode.
   */
  wire dq4;
  wire dq5;
  wire dq6;
  wire dq7;

  /**
   * These ports act as input/output when configured for Octal x16 Mode.
   */
  wire dq8;
  wire dq9;
  wire dq10;
  wire dq11;
  wire dq12;
  wire dq13;
  wire dq14;
  wire dq15;

  //----------------------------------------------------------------------------
  // Clocking Blocks
  //----------------------------------------------------------------------------
 
  clocking svt_spi_master_rx_cb @(sclk);
    default input  #`SVT_SPI_MONITOR_IF_SETUP_TIME
            output #`SVT_SPI_MONITOR_IF_HOLD_TIME;
    input  miso;
    input  parallel_io;
  endclocking

  clocking svt_spi_slave_rx_cb @(sclk);
    default input  #`SVT_SPI_MONITOR_IF_SETUP_TIME
            output #`SVT_SPI_MONITOR_IF_HOLD_TIME;
    input  mosi;
    input  parallel_io;
  endclocking

  clocking svt_spi_monitor_rx_cb @(sclk);
    default input  #`SVT_SPI_MONITOR_IF_SETUP_TIME
            output #`SVT_SPI_MONITOR_IF_HOLD_TIME;
    input  miso;
    input  mosi;
    input  parallel_io;
  endclocking

  clocking svt_spi_monitor_rx_bus_cb @(bus_clk);
    default input  #`SVT_SPI_MONITOR_IF_SETUP_TIME
            output #`SVT_SPI_MONITOR_IF_HOLD_TIME;
    input  sclk;
    input  slave_rdy;
    input  ss_n;
  endclocking

  //-----------------------------------------------------------------------
  // SPI Interface Debug Signals
  //-----------------------------------------------------------------------
  /**
   * Operation Mode 
   */
  bit [1:0] debug_operation_mode;

  /**
   * Bit Endianess 
   */
  bit debug_bit_endianness;
  
  /**
   * Byte Endianess 
   */
  bit debug_byte_endianness;

  /**
   * SPPR field of Baud Rate Divisor
   */
  bit [2:0] debug_sppr;
  
  /**
   * SPR field of Baud Rate Divisor
   */
  bit [2:0] debug_spr;
  
  /**
   * Data transmitted by Active agent on SPI Bus.
   */
  bit [`SVT_SPI_DATA_WIDTH-1:0] debug_tx_data_byte;
  
  /**
   * Data received by Agent on SPI Bus.
   */
  bit [`SVT_SPI_DATA_WIDTH-1:0] debug_rx_data_byte;

  /**
   * Upper Segment Data transmitted by Active agent on SPI Bus.
   */
  bit [`SVT_SPI_DATA_WIDTH-1:0] debug_tx_upper_data_partition0_byte;
  
  /**
   * Upper Segment Data received by Agent on SPI Bus.
   */
  bit [`SVT_SPI_DATA_WIDTH-1:0] debug_rx_upper_data_partition0_byte;

  /**
   * Instruction Bits in EEPROM/Multilane/Flash SPI mode
   */
  bit [31:0] debug_instruction_frame;

  /**
   * Address received in EEPROM/Multilane/Flash SPI mode
   */
  bit [31:0] debug_address_frame;

  /**
   * This signal specifies current Flash Device curent state
   */
  int debug_flash_device_state;

  /**
   * This signal specifies Flash Command Name.   
   */
  logic [255:0] debug_flash_command;

  /**
   * This signal specifies Flash Device's Curent State
   * This is applicable for devices which supports xSPI Profile 2.0
   */
  logic [255:0] debug_flash_prfl_2_0_current_device_state;

  /**
   * This signal specifies Flash Device's Next State
   * This is applicable for devices which supports xSPI Profile 2.0
   */
  logic [255:0] debug_flash_prfl_2_0_next_device_state;

  /**
   * This signal specifies Flash Command Name.   
   * This is applicable for devices which supports xSPI Profile 2.0
   */
  logic [255:0] debug_flash_prfl_2_0_flash_command;

  /**
   * This signal specifies Read/Write Type in Profile 2.0 Format's Command-Address(CA). <br/>
   * This is the 47th bit of CA Format. <br/>
   * 1 -> Read Type Command   <br/>
   * 0 -> Write Type Command  <br/>
   * This is applicable for devices which supports xSPI Profile 2.0
   */
  bit debug_flash_prfl_2_0_read_write;

  /**
   * This signal specifies Register/Memory Address Type in Profile 2.0 Format's Command-Address(CA). <br/>
   * This is the 46th bit of CA Format. <br/>
   * 1 -> Register Address  <br/>
   * 0 -> Memory Address    <br/>
   * This is applicable for devices which supports xSPI Profile 2.0
   */
  bit debug_flash_prfl_2_0_address_space;

  /**
   * This signal specifies Linear/Wrapped Burst Type in Profile 2.0 Format's Command-Address(CA). <br/>
   * This is the 45th bit of CA Format. <br/>
   * 1 -> Linear Burst   <br/>
   * 0 -> Wrapped Burst  <br/>
   * This is applicable for devices which supports xSPI Profile 2.0
   */
  bit debug_flash_prfl_2_0_burst_type;
  
  /**
   * Address CRC Tx/Rx when CRC Parity is enabled
   */
  bit[`SVT_SPI_MAX_ADDR_CRC_BIT_WIDTH-1:0] debug_address_crc;

  /**
   * Data CRC Transmitted when CRC Parity is enabled
   */
  bit[7:0] debug_tx_data_crc_byte;

  /**
   * Data CRC received when CRC Parity is enabled
   */
  bit[7:0] debug_rx_data_crc_byte;

  /**
   * ControlWord in feature set as MicroWire
   */
  bit [`SVT_SPI_UWIRE_MAX_CONTROL_WORD_WIDTH-1:0] debug_uwire_control_word;

  /**
   * Safe SPI Frame transmitted by Active agent.
   */
  bit [31:0] debug_tx_spi_safe_frame;

  /**
   * Safe SPI RX Frame received by Agent.
   */
  bit [31:0] debug_rx_spi_safe_frame;

  /**
   * Safe SPI Slave Select Address transmitted by Active agent.
   */
  bit [31:0] debug_tx_spi_safe_slave_select_address;

  /**
   * Safe SPI Slave Select Address received by Agent.
   */
  bit [31:0] debug_rx_spi_safe_slave_select_address;

  /**
   * Safe SPI Sensor Address transmitted by Active agent.
   */
  bit [31:0] debug_tx_spi_safe_sensor_address;

  /**
   * Safe SPI Sensor Address received by Agent.
   */
  bit [31:0] debug_rx_spi_safe_sensor_address;

  /**
   * Safe SPI CRC Frame transmitted by Active agent.
   */
  bit [`SVT_SPI_MAX_ADDR_CRC_BIT_WIDTH-1:0] debug_tx_spi_safe_crc_frame;

  /**
   * Safe SPI CRC Frame received by Agent.
   */
  bit [`SVT_SPI_MAX_ADDR_CRC_BIT_WIDTH-1:0] debug_rx_spi_safe_crc_frame;

  /**
   * This signal specifies whether Parallel Mode is enabled or not.
   */
  bit debug_parallel_io_mode;

  /**
   * Data transmitted by Active agent on Parallel Bus.
   */
  bit [`SVT_SPI_PIO_WIDTH:0] debug_tx_parallel_io_byte;
  
  /**
   * Data received by Agent on Parallel Bus. This port will output the
   * parallel data byte. 
   */
  bit [`SVT_SPI_PIO_WIDTH:0] debug_rx_parallel_io_byte;

  /**
   * This signal specifies whether TX FIFO is empty or not.
   * This pin is active for Slave Device Only when configuration bit svt_spi_configuration::enable_slave_rdy_feature is set. 
   */
  bit debug_tx_fifo_empty;

  /**
   * This signal specifies whether RX FIFO is full or not. <br/>
   * This pin is active for Slave Device Only when configuration bit svt_spi_configuration::enable_slave_rdy_feature is set. 
   */
  bit debug_rx_fifo_full;

  /**
   * Self Refresh Counter Value indicating which Row is self refreshed.
   */
  int debug_self_refresh_counter;

  /**
   * This signal indicates if self refresh is in progress.
   */
  bit debug_self_refresh_in_progress;

  /**
   * Using pull-up on RSTO to keep it HIGH when in HIGH impedance state
   */
  assign (pull1,pull0) rsto_n = '1;

  //----------------------------------------------------------------------------
  // Modports
  //----------------------------------------------------------------------------
 
  modport svt_spi_master_modport (
    input  reset,
    input  miso,
    inout  dqs,
    input  ecs_n,
    input  int_n,
    input  ss_in_n,
    input  slave_rdy,
    output sclk,
    output ss_n,
    output oe_n,
    output mosi,
    output Vcc,
    output Vss,
    output rsto_n,
    output vpp,
    output hold_n,
    output write_protect_n,
    inout  hsb_n,
    inout  parallel_io,
    output parallel_io_oe_n
    );

  modport svt_spi_slave_modport (
    input  reset,
    input  ss_n,
    input  sclk,
    input  mosi,
    input  Vcc,
    input  Vss,
    input  vpp,
    input  rsto_n,
    input  hold_n,
    input  write_protect_n,
    output oe_n,
    output miso,
    inout  dqs,
    output ecs_n,
    output int_n,
    inout  hsb_n,
    inout  parallel_io,
    output parallel_io_oe_n,
    output slave_rdy
    );

  modport svt_spi_master_slave_monitor_modport (
    input reset,
    input sclk,
    input ss_n,
    input ss_in_n,
    input oe_n,
    input spi_interrupt,
    input miso,
    input mosi,
    input Vcc,
    input Vss,
    input vpp,
    input rsto_n,
    input hold_n,
    input write_protect_n,
    input hsb_n,
    input dqs,
    input ecs_n,
    input int_n,
    input parallel_io_oe_n,
    input parallel_io,
    input slave_rdy
    );
 
  modport svt_spi_master_slave_debug_modport (
    output debug_rx_data_byte,
    output debug_tx_data_byte,
    output debug_rx_upper_data_partition0_byte,
    output debug_tx_upper_data_partition0_byte,
    output debug_operation_mode,         
    output debug_bit_endianness,        
    output debug_byte_endianness,        
    output debug_sppr,                   
    output debug_spr,
    output debug_instruction_frame,
    output debug_address_frame,
    output debug_flash_device_state,
    output debug_flash_command,
    output debug_flash_prfl_2_0_current_device_state,
    output debug_flash_prfl_2_0_next_device_state,
    output debug_flash_prfl_2_0_flash_command,
    output debug_flash_prfl_2_0_read_write,
    output debug_flash_prfl_2_0_address_space,
    output debug_flash_prfl_2_0_burst_type,
    output debug_address_crc,
    output debug_tx_data_crc_byte,
    output debug_rx_data_crc_byte,
    output debug_uwire_control_word,
    output debug_tx_spi_safe_frame, 
    output debug_rx_spi_safe_frame, 
    output debug_tx_spi_safe_slave_select_address,
    output debug_rx_spi_safe_slave_select_address,
    output debug_tx_spi_safe_sensor_address,
    output debug_rx_spi_safe_sensor_address,
    output debug_tx_spi_safe_crc_frame,
    output debug_rx_spi_safe_crc_frame,
    output debug_parallel_io_mode,
    output debug_tx_parallel_io_byte,
    output debug_rx_parallel_io_byte,
    output debug_tx_fifo_empty,
    output debug_rx_fifo_full,
    output debug_self_refresh_counter,
    output debug_self_refresh_in_progress
    );

  //-----------------------------------------------------------------------
  // SPI Serial Interface Control Signals
  //-----------------------------------------------------------------------
  
  /**
   * Indicates whether active Master component present to drive the SPI
   */
  reg  active_master = 1'b0; 

  /**
   * Indicates whether active Slave component present to drive the SPI
   */
  reg  active_slave = 1'b0; 

  /**
   * Indicates whether passive Slave component present to drive the SPI
   */
  reg  passive_slave = 1'b0; 

  reg  [(`SVT_SPI_IO_WIDTH-1):0] passive_slave_sample_n = {`SVT_SPI_IO_WIDTH{1'b1}}; //Passive Slave Sample Enable. Indicates when Slave output(MISO) is to read. If set to 0, Passive Monitor agent reads MOSI line.
  reg  gtx_sclk = 1'bz;                                      // Used for transmission of sclk
  reg  [(`SVT_SPI_IO_WIDTH-1):0] gtx_mosi = {`SVT_SPI_IO_WIDTH{1'bz}};  // Used for transmission of mosi
  reg  [(`SVT_SPI_IO_WIDTH-1):0] gtx_miso = {`SVT_SPI_IO_WIDTH{1'bz}}; // Used for transmission of miso
  reg  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] gtx_ss_n = {`SVT_SPI_MAX_NUM_SLAVES{1'bz}};      // Used for transmission of ss_n
  reg  [(`SVT_SPI_IO_WIDTH-1):0] gtx_oe_n = {`SVT_SPI_IO_WIDTH{1'b1}};
  reg  Vcc_reg = 1'bz;                                // To Drive Vcc port
  reg  Vss_reg = 1'bz;                                // To Drive Vss port
  reg  rsto_n_reg = 1'bz;                               // To Drive rsto_n port
  reg  gtx_hsb_n = 1'bz;                              // Used for transmission of hsb_n
  reg  hsb_oe_n = 1'b1;                               // Indicates valid for gtx_hsb_n  
  reg  [(`SVT_SPI_MAX_DQS_WIDTH-1):0] dm_oe_n = {`SVT_SPI_MAX_DQS_WIDTH{1'b1}};     // Indicates valid for gtx_dm
  reg  [(`SVT_SPI_MAX_DQS_WIDTH-1):0] dqs_oe_n = {`SVT_SPI_MAX_DQS_WIDTH{1'b1}};    // Indicates valid for gtx_dqs 
  reg  [(`SVT_SPI_MAX_DQS_WIDTH-1):0] gtx_dqs = {`SVT_SPI_MAX_DQS_WIDTH{1'bz}};
  reg  [(`SVT_SPI_MAX_DQS_WIDTH-1):0] gtx_dm = {`SVT_SPI_MAX_DQS_WIDTH{1'bz}};
  reg  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] gtx_vpp = `SVT_SPI_MAX_NUM_SLAVES'hz;
  reg  gtx_hold_n = 1'bz;
  reg  gtx_write_protect_n = 1'bz;
  reg  gtx_ecs_n = 1'bz;
  reg  gtx_int_n = 1'bz;
  reg  [(`SVT_SPI_PIO_WIDTH-1):0] gtx_parallel_io_oe_n = {`SVT_SPI_PIO_WIDTH{1'b1}};
  reg  [(`SVT_SPI_PIO_WIDTH-1):0] gtx_parallel_io      = {`SVT_SPI_PIO_WIDTH{1'bz}}; // Used for transmission of po
  reg  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] gtx_slave_rdy = {`SVT_SPI_MAX_NUM_SLAVES{1'bz}};      // Used for transmission of slave_rdy

  logic  grx_sclk;                                    // Used for reception of sclk
  logic  [(`SVT_SPI_IO_WIDTH-1):0] grx_mosi;          // Used for reception of mosi
  logic  [(`SVT_SPI_IO_WIDTH-1):0] grx_miso;          // Used for reception of miso
  logic  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] grx_ss_n;    // Used for reception of ss_n
  logic  grx_ss_in_n;// Used for reception of ss_in_n
  logic  [(`SVT_SPI_PIO_WIDTH-1):0] grx_parallel_io;  // Used for reception of po
  logic  grx_hsb_n;                                   //Used for reception of hsb_n                         
  logic  [(`SVT_SPI_MAX_DQS_WIDTH-1):0] grx_dqs;
  logic  [(`SVT_SPI_MAX_DQS_WIDTH-1):0] grx_dm;
  logic  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] grx_vpp;
  logic  grx_hold_n;
  logic  grx_write_protect_n;
  logic  grx_ecs_n;
  logic  grx_int_n;
  logic  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] grx_slave_rdy;    // Used for reception of slave_rdy

  // Weak External Pull up on hsb_n port for Idle state value.
  assign (weak1,weak0) hsb_n = 1'b1; 
  assign Vcc = Vcc_reg;
  assign Vss = Vss_reg;

  assign rsto_n = rsto_n_reg;

`protect
`ifndef __SVDOC__
  real tSCLK_fly_by_delay_ns = 0;
  real tMISO_fly_by_delay_ns[`SVT_SPI_IO_WIDTH] = '{`SVT_SPI_IO_WIDTH{0}};
  real tMOSI_fly_by_delay_ns[`SVT_SPI_IO_WIDTH] = '{`SVT_SPI_IO_WIDTH{0}};
  real tOE_N_fly_by_delay_ns[`SVT_SPI_IO_WIDTH] = '{`SVT_SPI_IO_WIDTH{0}};
  real tPARALLEL_IO_OE_N_fly_by_delay_ns[`SVT_SPI_PIO_WIDTH] = '{`SVT_SPI_PIO_WIDTH{0}};
  real tPARALLEL_IO_fly_by_delay_ns[`SVT_SPI_PIO_WIDTH]      = '{`SVT_SPI_PIO_WIDTH{0}};
  real tSS_N_fly_by_delay_ns;
  real tSLAVE_RDY_fly_by_delay_ns;
  real tSPI_INTERRUPT_fly_by_delay_ns;
  real tHSB_N_fly_by_delay_ns = 0;
  real tDQS_fly_by_delay_ns[`SVT_SPI_MAX_DQS_WIDTH] = '{`SVT_SPI_MAX_DQS_WIDTH{0}};
  real tVPP_fly_by_delay_ns; 
  real tHOLD_N_fly_by_delay_ns = 0; 
  real tWRITE_PROTECT_N_fly_by_delay_ns = 0; 
  real tECS_N_fly_by_delay_ns = 0; 
  real tINT_N_fly_by_delay_ns = 0; 
  genvar mosi_lane_num;
  genvar miso_lane_num;
  genvar oe_lane_num;
  genvar dqs_lane_num;
  genvar parallel_io_lane_num;
  genvar parallel_io_oe_lane_num;

`ifdef SVT_SPI_NON_NBA_DELAY_MODEL
  // For Transmit on SPI Bus
  assign #(tSCLK_fly_by_delay_ns * 1ns) sclk = (active_master) ? gtx_sclk :1'bz;
  generate
    for (mosi_lane_num=0; mosi_lane_num < `SVT_SPI_IO_WIDTH; mosi_lane_num=mosi_lane_num+1) begin :SPI_IO_DELAY_MOSI
      assign #(tMOSI_fly_by_delay_ns[mosi_lane_num] * 1ns) mosi[mosi_lane_num] = (active_master) ? gtx_mosi[mosi_lane_num] :1'bz;
    end
  endgenerate

  generate
    for (miso_lane_num=0; miso_lane_num < `SVT_SPI_IO_WIDTH; miso_lane_num=miso_lane_num+1) begin :SPI_IO_DELAY_MISO
      assign #(tMISO_fly_by_delay_ns[miso_lane_num] * 1ns) miso[miso_lane_num] = (active_slave) ? gtx_miso[miso_lane_num] :1'bz;
    end
  endgenerate

  generate
    for (parallel_io_lane_num=0; parallel_io_lane_num < `SVT_SPI_PIO_WIDTH; parallel_io_lane_num=parallel_io_lane_num+1) begin :SPI_IO_DELAY_PARALLEL_IO
      assign #(tPARALLEL_IO_fly_by_delay_ns[parallel_io_lane_num] * 1ns) parallel_io[parallel_io_lane_num] = (~gtx_parallel_io_oe_n[parallel_io_lane_num]) ? gtx_parallel_io[parallel_io_lane_num] :1'bz;
    end
  endgenerate

  assign #(tSS_N_fly_by_delay_ns * 1ns) ss_n = (active_master) ? gtx_ss_n :{`SVT_SPI_MAX_NUM_SLAVES{1'bz}};
  assign #(tSLAVE_RDY_fly_by_delay_ns * 1ns) slave_rdy = active_slave ? gtx_slave_rdy : {`SVT_SPI_MAX_NUM_SLAVES{1'bz}};
  assign #(tSPI_INTERRUPT_fly_by_delay_ns * 1ns) spi_interrupt = (spif || sptef || modf); 

  generate
    for (oe_lane_num=0; oe_lane_num < `SVT_SPI_IO_WIDTH; oe_lane_num=oe_lane_num+1) begin :SPI_IO_DELAY_OE
      assign #(tOE_N_fly_by_delay_ns[oe_lane_num] * 1ns) oe_n[oe_lane_num] = gtx_oe_n[oe_lane_num];
    end
  endgenerate

  generate
    for (parallel_io_oe_lane_num=0; parallel_io_oe_lane_num < `SVT_SPI_PIO_WIDTH; parallel_io_oe_lane_num=parallel_io_oe_lane_num+1) begin :SPI_DELAY_PARALLEL_IO_OE
      assign #(tPARALLEL_IO_OE_N_fly_by_delay_ns[parallel_io_oe_lane_num] * 1ns) parallel_io_oe_n[parallel_io_oe_lane_num] = gtx_parallel_io_oe_n[parallel_io_oe_lane_num];
    end
  endgenerate

  assign #(tHSB_N_fly_by_delay_ns * 1ns) hsb_n = ~hsb_oe_n ? gtx_hsb_n : 1'bz; 
  //assign (strong1,strong0) hsb_n = (active_slave && ~hsb_oe_n) ? gtx_hsb_n : 1'bz; 
  //assign (pull1,pull0) hsb_n = (active_master && ~hsb_oe_n) ? gtx_hsb_n : 1'bz; 
  generate
    for (dqs_lane_num=0; dqs_lane_num < `SVT_SPI_MAX_DQS_WIDTH; dqs_lane_num=dqs_lane_num+1) begin :SPI_IO_DELAY_DQS
      assign #(tDQS_fly_by_delay_ns[dqs_lane_num] * 1ns) dqs[dqs_lane_num] = (~dqs_oe_n[dqs_lane_num]) ?  gtx_dqs[dqs_lane_num] : (~dm_oe_n[dqs_lane_num]) ? gtx_dm[dqs_lane_num] : 1'bz;
    end
  endgenerate

  assign #( tVPP_fly_by_delay_ns* 1ns) vpp =  gtx_vpp ;
  assign #( tHOLD_N_fly_by_delay_ns * 1ns) hold_n = (active_master) ? gtx_hold_n :1'bz;
  assign #( tWRITE_PROTECT_N_fly_by_delay_ns* 1ns) write_protect_n = (active_master) ? gtx_write_protect_n :1'bz ;
  assign #(tECS_N_fly_by_delay_ns * 1ns) ecs_n = (active_slave) ?  gtx_ecs_n : 1'bz;
  assign #(tINT_N_fly_by_delay_ns * 1ns) int_n = gtx_int_n ;
`else
  reg reg_sclk = 1'bz;
  reg  [(`SVT_SPI_IO_WIDTH-1):0] reg_mosi = {`SVT_SPI_IO_WIDTH{1'bz}};
  reg  [(`SVT_SPI_IO_WIDTH-1):0] reg_miso = {`SVT_SPI_IO_WIDTH{1'bz}};
  reg  [(`SVT_SPI_PIO_WIDTH-1):0] reg_parallel_io   = {`SVT_SPI_PIO_WIDTH{1'bz}};
  reg  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] reg_ss_n = {`SVT_SPI_MAX_NUM_SLAVES{1'bz}};
  reg  [(`SVT_SPI_IO_WIDTH-1):0] reg_oe_n  = {`SVT_SPI_IO_WIDTH{1'b1}};
  reg  [(`SVT_SPI_PIO_WIDTH-1):0] reg_parallel_io_oe_n = {`SVT_SPI_PIO_WIDTH{1'b1}};
  reg reg_hsb_n = 1'bz;
  reg [(`SVT_SPI_MAX_DQS_WIDTH-1):0] reg_dqs = {`SVT_SPI_MAX_DQS_WIDTH{1'bz}};
  reg [(`SVT_SPI_MAX_NUM_SLAVES-1):0] reg_vpp = {`SVT_SPI_MAX_NUM_SLAVES{1'bz}}; 
  reg reg_hold_n = 1'bz;
  reg reg_write_protect_n = 1'bz;
  reg reg_ecs_n = 1'bz;
  reg reg_int_n = 1'bz;
  reg  [(`SVT_SPI_MAX_NUM_SLAVES-1):0] reg_slave_rdy = {`SVT_SPI_MAX_NUM_SLAVES{1'bz}};
  
  assign sclk = reg_sclk;
  always @ (active_master,gtx_sclk) begin
    reg_sclk <= #(tSCLK_fly_by_delay_ns * 1ns) active_master ? gtx_sclk : 1'bz;
  end


  assign mosi = reg_mosi;
  generate
    for (mosi_lane_num=0; mosi_lane_num < `SVT_SPI_IO_WIDTH; mosi_lane_num=mosi_lane_num+1) begin :SPI_IO_DELAY_MOSI
      always @ (active_master,gtx_mosi[mosi_lane_num]) begin
        reg_mosi[mosi_lane_num] <= #(tMOSI_fly_by_delay_ns[mosi_lane_num] * 1ns) active_master ? gtx_mosi[mosi_lane_num] : 1'bz ;
      end
    end
  endgenerate

  assign miso = reg_miso;
  generate
    for (miso_lane_num=0; miso_lane_num < `SVT_SPI_IO_WIDTH; miso_lane_num=miso_lane_num+1) begin :SPI_IO_DELAY_MISO
      always @ (active_slave,gtx_miso[miso_lane_num]) begin
        reg_miso[miso_lane_num] <= #(tMISO_fly_by_delay_ns[miso_lane_num] * 1ns) active_slave ? gtx_miso[miso_lane_num] : 1'bz;
      end
    end
  endgenerate
 
  assign parallel_io = reg_parallel_io;
  generate
    for (parallel_io_lane_num=0; parallel_io_lane_num < `SVT_SPI_PIO_WIDTH; parallel_io_lane_num=parallel_io_lane_num+1) begin :SPI_IO_DELAY_PARALLEL_IO
      always @ (gtx_parallel_io[parallel_io_lane_num] or gtx_parallel_io_oe_n[parallel_io_lane_num]) begin
        reg_parallel_io[parallel_io_lane_num] <= #(tPARALLEL_IO_fly_by_delay_ns[parallel_io_lane_num] * 1ns) (~gtx_parallel_io_oe_n[parallel_io_lane_num]) ? gtx_parallel_io[parallel_io_lane_num] : 1'bz;
      end
    end
  endgenerate

  assign ss_n = reg_ss_n;
  always @ (active_master,gtx_ss_n) begin
    reg_ss_n <= #(tSS_N_fly_by_delay_ns * 1ns) active_master ? gtx_ss_n : {`SVT_SPI_MAX_NUM_SLAVES{1'bz}};
  end

  assign slave_rdy = reg_slave_rdy;
  always @ (active_slave,gtx_slave_rdy)
    reg_slave_rdy <= #(tSLAVE_RDY_fly_by_delay_ns * 1ns) gtx_slave_rdy;

  always @ (spif or sptef or modf) begin
    spi_interrupt <= #(tSPI_INTERRUPT_fly_by_delay_ns * 1ns) (spif || sptef || modf);
  end
  
  assign oe_n = reg_oe_n;
  generate
    for (oe_lane_num=0; oe_lane_num < `SVT_SPI_IO_WIDTH; oe_lane_num=oe_lane_num+1) begin :SPI_IO_DELAY_OE
      always @ (gtx_oe_n[oe_lane_num]) begin
        reg_oe_n[oe_lane_num] <= #(tOE_N_fly_by_delay_ns[oe_lane_num] * 1ns) gtx_oe_n[oe_lane_num];
      end
    end
  endgenerate
 
  assign parallel_io_oe_n = reg_parallel_io_oe_n;
  generate
    for (parallel_io_oe_lane_num=0; parallel_io_oe_lane_num < `SVT_SPI_PIO_WIDTH; parallel_io_oe_lane_num=parallel_io_oe_lane_num+1) begin :SPI_IO_DELAY_PARALLEL_OE_N
      always @ (gtx_parallel_io_oe_n[parallel_io_oe_lane_num]) begin
        reg_parallel_io_oe_n[parallel_io_oe_lane_num] <= #(tPARALLEL_IO_OE_N_fly_by_delay_ns[parallel_io_oe_lane_num] * 1ns) gtx_parallel_io_oe_n[parallel_io_oe_lane_num];
      end
    end
  endgenerate

  assign hsb_n = reg_hsb_n;
  always @(gtx_hsb_n or hsb_oe_n) begin
    reg_hsb_n <= #(tHSB_N_fly_by_delay_ns * 1ns) ~hsb_oe_n ? gtx_hsb_n : 1'bz;
  end

  assign dqs = reg_dqs;
  generate
    for (dqs_lane_num=0; dqs_lane_num < `SVT_SPI_MAX_DQS_WIDTH; dqs_lane_num=dqs_lane_num+1) begin :SPI_IO_DELAY_DQS
      always @(gtx_dqs or dqs_oe_n or dm_oe_n or gtx_dm) begin
        reg_dqs[dqs_lane_num] <= #(tDQS_fly_by_delay_ns[dqs_lane_num] * 1ns) (~dqs_oe_n[dqs_lane_num]) ? gtx_dqs[dqs_lane_num] : (~dm_oe_n[dqs_lane_num]) ? gtx_dm[dqs_lane_num] : 1'bz;
      end
    end  
  endgenerate  
  
  assign vpp = reg_vpp;
  always @(gtx_vpp) begin
    reg_vpp <= #( tVPP_fly_by_delay_ns* 1ns) gtx_vpp ;
  end

  assign hold_n = reg_hold_n;
  always @(gtx_hold_n or active_master) begin
    reg_hold_n <=  #( tHOLD_N_fly_by_delay_ns * 1ns) (active_master) ? gtx_hold_n :1'bz;
  end

  assign write_protect_n = reg_write_protect_n;
  always @(active_master or gtx_write_protect_n) begin
    reg_write_protect_n <= #( tWRITE_PROTECT_N_fly_by_delay_ns* 1ns) (active_master) ? gtx_write_protect_n :1'bz ;
  end

  assign ecs_n = reg_ecs_n;
  always @(active_slave or gtx_ecs_n) begin
    reg_ecs_n <= #( tECS_N_fly_by_delay_ns* 1ns) (active_slave) ? gtx_ecs_n :1'bz ;
  end

  assign int_n = reg_int_n;
  always @(gtx_int_n) begin
    reg_int_n <= #( tINT_N_fly_by_delay_ns* 1ns) gtx_int_n ;
  end
`endif

  // For Reception
  assign grx_sclk  = sclk; 
  assign grx_mosi  = mosi; 
  assign grx_miso  = miso;
  assign grx_parallel_io = (parallel_io_oe_n) ? parallel_io : {`SVT_SPI_PIO_WIDTH{1'bz}};
  assign grx_ss_n  = ss_n;
  assign grx_ss_in_n  = ss_in_n;
  assign grx_hsb_n = hsb_n;
  assign grx_dqs   = (active_master && dm_oe_n) ? dqs : {`SVT_SPI_MAX_DQS_WIDTH{1'bZ}};
  assign grx_dm    = (active_slave) ? dqs : {`SVT_SPI_MAX_DQS_WIDTH{1'bZ}};
  assign grx_vpp   = vpp;
  assign grx_hold_n = hold_n;
  assign grx_write_protect_n = write_protect_n;
  assign grx_ecs_n = ecs_n;
  assign grx_int_n = int_n;
  assign grx_slave_rdy  = slave_rdy;
`endif
`endprotect
 
  //-----------------------------------------------------------------------
  // SPI Flash Port using SPI Generic signals 
  //-----------------------------------------------------------------------

  /**
   * Specifes that Vpp mode is enabled 
   */
  reg spi_flash_vpp_acclerator_en = 1'b0;

  /** 
   * Specifies that current transaction has Extended SPI protocol mode  
   * without I/O in address and Data Phase.
   */
  reg spi_flash_espi_wo_io = 1'b0;


`ifndef __SVDOC__
  /* Index for Lane number */ 
  genvar lane_num;
  generate
    for (lane_num=0; lane_num < `SVT_SPI_IO_WIDTH; lane_num=lane_num+1) begin :SPI_FLASH_IO_CONNECT
      case(lane_num)
        0 : begin:LANE_NUM_0
              //Slave drive connections
              assign dq0 = (spi_flash_espi_wo_io & active_slave) ? 1'bz 
                                                       :(~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;
              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (spi_flash_espi_wo_io ? dq0 : (passive_slave_sample_n[lane_num] ? dq0 : 1'bz))
                                                    : (spi_flash_espi_wo_io & active_slave) ? dq0
                                                                                            : (oe_n[lane_num] && ~active_master) ? dq0 : 1'bz;

              //Master drive connections
              assign dq0 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;

              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (spi_flash_espi_wo_io ? dq1 : (~passive_slave_sample_n[lane_num] ? dq0 : 1'bz))
                                                    : (spi_flash_espi_wo_io & active_master) ? dq1 
                                                                                             : (oe_n[lane_num] && active_master) ? dq0 : 1'bz;
            end
         1: begin:LANE_NUM_1
              //Slave drive connections
              assign dq1 = (spi_flash_espi_wo_io & active_slave) ? ((~oe_n[lane_num-1] && active_slave) ? miso[lane_num-1] : 1'bz)
                                                       : (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;
              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (spi_flash_espi_wo_io ? 1'bz : (passive_slave_sample_n[lane_num] ? dq1 : 1'bz))
                                                    : (spi_flash_espi_wo_io & active_slave) ? 1'bz
                                                                                            : (oe_n[lane_num] && ~active_master) ? dq1 : 1'bz;
              
              //Master drive connections
              assign dq1 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (spi_flash_espi_wo_io ? 1'bz : (~passive_slave_sample_n[lane_num] ? dq1 : 1'bz))
                                                    : (spi_flash_espi_wo_io & active_master) ? 1'bz 
                                                                                             : (oe_n[lane_num] && active_master) ? dq1 : 1'bz;
            end

         2: begin:LANE_NUM_2
              //Slave drive connections
              assign dq2 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq2 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq2 :1'bz;
              
              //Master drive connections
              assign dq2 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq2 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq2 : 1'bz;
            end

         3: begin:LANE_NUM_3
              //Slave drive connections
              assign dq3 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq3 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq3 :1'bz;
              
              //Master drive connections
              assign dq3 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq3 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq3 : 1'bz;

            end
         4: begin:LANE_NUM_4
              //Slave drive connections
              assign dq4 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq4 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq4 :1'bz;
              
              //Master drive connections
              assign dq4 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq4 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq4 : 1'bz;

            end
         5: begin:LANE_NUM_5
              //Slave drive connections
              assign dq5 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq5 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq5 :1'bz;
              
              //Master drive connections
              assign dq5 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq5 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq5 : 1'bz;

            end
         6: begin:LANE_NUM_6
              //Slave drive connections
              assign dq6 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq6 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq6 :1'bz;
              
              //Master drive connections
              assign dq6 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq6 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq6 : 1'bz;

            end
         7: begin:LANE_NUM_7
              //Slave drive connections
              assign dq7 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq7 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq7 :1'bz;
              
              //Master drive connections
              assign dq7 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq7 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq7 : 1'bz;

            end
         8: begin:LANE_NUM_8
              //Slave drive connections
              assign dq8 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq8 : 1'bz) 
                                                    : (oe_n[lane_num] && ~active_master) ? dq8 :1'bz;
              
              //Master drive connections
              assign dq8 = (~oe_n[lane_num] && active_master) ? mosi[lane_num] : 1'bz;
              
              //Master Sample connections
              assign miso[lane_num] = passive_slave ? (~passive_slave_sample_n[lane_num] ? dq8 : 1'bz)
                                                    : (oe_n[lane_num] && active_master) ? dq8 : 1'bz;

            end
         9: begin:LANE_NUM_9
              //Slave drive connections
              assign dq9 = (~oe_n[lane_num] && active_slave) ? miso[lane_num] : 1'bz;

              //Slave Sample connections
              assign mosi[lane_num] = passive_slave ? (passive_slave_sample_n[lane_num] ? dq9 : 1'bz) 
