/** @cond PRIVATE */

`ifdef SVT_VMM_TECHNOLOGY

 `define SVT_EVENT_DECL(ev_name) \
    int NOTIFY_``ev_name;

 `define SVT_EVENT_INIT_EVENT(ev_name) \
    NOTIFY_``ev_name = this.notify.configure(, vmm_notify::ONE_SHOT); 

 `define SVT_EVENT_INIT_PEVENT(ev_name) \
    NOTIFY_``ev_name = this.notify.configure(, vmm_notify::BLAST); 

 `define SVT_EVENT_INIT_ONOFF_EVENT(ev_name) \
    NOTIFY_``ev_name = this.notify.configure(, vmm_notify::ON_OFF); 

  `define SVT_EVENT_TRIGGER_EVENT(ev_name) \
    this.notify.indicate(NOTIFY_``ev_name);

  `define SVT_EVENT_TRIGGER_EVENT_W_DATA(ev_name,ev_obj) \
    this.notify.indicate(NOTIFY_``ev_name,ev_obj);

  `define SVT_EVENT_WAIT_EVENT(ev_name) \
    this.notify.wait_for(NOTIFY_``ev_name); 

  `define SVT_EVENT_WAIT_EVENT_W_DATA(ev_name,ev_obj) \
    this.notify.wait_for(NOTIFY_``ev_name); \
    ev_obj = this.notify.status(NOTIFY_``ev_name);

  `define SVT_EVENT_WAIT_PEVENT(ev_name) \
    `SVT_EVENT_WAIT_EVENT(ev_name)

  `define SVT_EVENT_WAIT_PEVENT_W_DATA(ev_name,ev_obj) \
    `SVT_EVENT_WAIT_EVENT_W_DATA(ev_name,ev_obj)
  
  `define SVT_EVENT_WAIT_ON(ev_name) \
    this.notify.wait_for(NOTIFY_``ev_name);

  `define SVT_EVENT_WAIT_OFF(ev_name) \
    this.notify.wait_for_off(NOTIFY_``ev_name);

  `define SVT_EVENT_GET_TRIGGER_DATA(ev_name,ev_obj) \
    ev_obj = this.notify.status(NOTIFY_``ev_name);

`else

 `define SVT_EVENT_DECL(ev_name) \
    `SVT_XVM(event) EVENT_``ev_name;

 `define SVT_EVENT_INIT_EVENT(ev_name) \
    EVENT_``ev_name = new({"EVENT_", `"ev_name`"});

 `define SVT_EVENT_INIT_PEVENT(ev_name) \
    `SVT_EVENT_INIT_EVENT(ev_name)

 `define SVT_EVENT_INIT_ONOFF_EVENT(ev_name) \
    `SVT_EVENT_INIT_EVENT(ev_name)

  `define SVT_EVENT_TRIGGER_EVENT(ev_name) \
    EVENT_``ev_name.trigger();

  `define SVT_EVENT_TRIGGER_EVENT_W_DATA(ev_name,ev_obj) \
    EVENT_``ev_name.trigger(ev_obj);

  `define SVT_EVENT_WAIT_EVENT(ev_name) \
    EVENT_``ev_name.wait_trigger();

  `define SVT_EVENT_WAIT_EVENT_W_DATA(ev_name,ev_obj) \
    EVENT_``ev_name.wait_trigger_data(ev_obj);

  `define SVT_EVENT_WAIT_PEVENT(ev_name) \
    EVENT_``ev_name.wait_ptrigger();
  
  `define SVT_EVENT_WAIT_PEVENT_W_DATA(ev_name,ev_obj) \
    EVENT_``ev_name.wait_ptrigger_data(ev_obj);

  `define SVT_EVENT_WAIT_ON(ev_name) \
    EVENT_``ev_name.wait_on();

  `define SVT_EVENT_WAIT_OFF(ev_name) \
    EVENT_``ev_name.wait_off();

  `define SVT_EVENT_GET_TRIGGER_DATA(ev_name,ev_obj) \
    ev_obj = EVENT_``ev_name.get_trigger_data();

`endif

/** @endcond */

`endif // GUARD_SVT_EVENT_UTIL_SVI
