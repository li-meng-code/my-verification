
`ifndef GUARD_SVT_SPI_TXRX_DEF_COV_UTIL_SV
`define GUARD_SVT_SPI_TXRX_DEF_COV_UTIL_SV

/** @cond PRIVATE */

/**
 * Macro to declare SPI STD covergroup template
 */
`define SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(signal_name, sample_event) \
  covergroup signal_state_``signal_name @(sample_event); \
    option.per_instance = 1; \
    option.goal = 100; 

/**
 * Macro to declare SPI Flash covergroup template
 */
`define SVT_SPI_TXRX_MONITOR_DEF_FLASH_COV_UTIL_CG(signal_name, sample_event) \
  covergroup signal_state_``signal_name (input svt_spi_types::flash_protocol_mode_enum arg1, input svt_spi_types::flash_protocol_mode_enum arg2, input svt_spi_types::flash_protocol_mode_enum argr3, input svt_spi_types::flash_protocol_mode_enum arg4 = svt_spi_types::UNDEF, input svt_spi_types::flash_protocol_mode_enum arg5 = svt_spi_types::UNDEF) @(sample_event); \
    option.per_instance = 1; \
    option.goal = 100;

/**
 * Macro to create SPI STD state covergroup instances 
 */
`define SVT_SPI_MONITOR_DEF_COV_UTIL_SET_STATE_CG_INST_NAME(signal_name,name) \
   signal_state_``signal_name = new(); \
   signal_state_``signal_name.set_inst_name($sformatf("%0s_%0s", name, `SVT_DATA_UTIL_ARG_TO_STRING(signal_name)));

`define SVT_SPI_MONITOR_DEF_FLASH_COV_UTIL_SET_STATE_CG_INST_NAME(signal_name,name,arg1,arg2,argr3,arg4,arg5) \
   signal_state_``signal_name = new(arg1,arg2,argr3,arg4,arg5); \
   signal_state_``signal_name.set_inst_name($sformatf("%0s_%0s", name, `SVT_DATA_UTIL_ARG_TO_STRING(signal_name)));

`define SVT_SPI_MONITOR_DEF_COV_UTIL_COMMON_CONFIGURATION(sample_point) \
   CP_BIT_ENDIANNESS : coverpoint (sample_point.bit_endianness)  \
   { \
    bins CB_BIG_ENDIAN    = {svt_spi_types::BIG_ENDIAN}; \
    bins CB_LITTLE_ENDIAN = {svt_spi_types::LITTLE_ENDIAN}; \
   } \
   CP_BYTE_ENDIANNESS : coverpoint (sample_point.byte_endianness)  \
   { \
    bins CB_BIG_ENDIAN    = {svt_spi_types::BIG_ENDIAN}; \
    bins CB_LITTLE_ENDIAN = {svt_spi_types::LITTLE_ENDIAN}; \
   } \
   CP_PAYLOAD_WORD_SIZE : coverpoint (sample_point.payload_word_size)  \
   { \
    bins CB_8BIT_WORD  = {svt_spi_types::SPI_8B}; \
    bins CB_16BIT_WORD = {svt_spi_types::SPI_16B}; \
    bins CB_32BIT_WORD = {svt_spi_types::SPI_32B}; \
   } 

`define SVT_SPI_SAFE_MONITOR_DEF_COV_UTIL_COMMON_CONFIGURATION(sample_point) \
   CP_FRAME_FORMAT : coverpoint(sample_point.frame_format) \
   { \
    bins CB_SPI_SAFE = {svt_spi_types::SPI_SAFE}; \
   } \
   CP_OPERATION_MODE : coverpoint (sample_point.operation_mode)  \
   { \
    bins CB_MODE_0 = {svt_spi_types::SPI_MODE_0}; \
    bins CB_MODE_1 = {svt_spi_types::SPI_MODE_1}; \
   } \
   CP_CS_TYPE : coverpoint(sample_point.cs_type) \
   { \
    bins CB_DEDICATED_CS = {svt_spi_types::DEDICATED_CS}; \
    bins CB_COMMON_CS    = {svt_spi_types::COMMON_CS}; \
   } \
   CP_SPI_SAFE_FRAME_MODE : coverpoint(sample_point.spi_safe_frame_mode) \
   { \
    bins CB_IN_FRAME     = {svt_spi_types::IN_FRAME}; \
    bins CB_OUT_OF_FRAME = {svt_spi_types::OUT_OF_FRAME}; \
   } \

`define SVT_SPI_MONITOR_DEF_COV_UTIL_UWIRE_COMMON_CONFIGURATION(sample_point) \
   CP_DATA_FRAME_WIDTH : coverpoint (sample_point.data_frame_width) \
   { \
    bins CB_WIDTH_1_TO_8  = {[1:8]}; \
    bins CB_WIDTH_9_TO_16 = {[9:16]}; \
    bins CB_WIDTH_17_TO_24 = {[17:24]}; \
    bins CB_WIDTH_25_TO_32 = {[25:32]}; \
   } \
   CP_UWIRE_CONTROL_WORD_WIDTH : coverpoint (sample_point.uwire_control_word_width) \
   { \
    bins CB_UWIRE_CWORD_WIDTH_1_TO_8  = {[1:8]}; \
    bins CB_UWIRE_CWORD_WIDTH_9_TO_16 = {[9:16]}; \
   } \
   CP_UWIRE_ENABLE_HANDSHAKING_MODE : coverpoint (sample_point.uwire_enable_handshaking_mode) \
   { \
    bins CB_ENABLE_HANDSHAKING_MODE = {1'b1}; \
   } 

`define SVT_SPI_MONITOR_DEF_COV_UTIL_COMMON_TRANSACTION(sample_point) \
   CP_TIMER_TRAILING : coverpoint (sample_point.timer_trailing) \
   { \
    bins CB_TIMER_1         = {1}; \
    bins CB_TIMER_2_TO_MAX  = {[2:`SVT_SPI_MAX_TRAILING_TIME]}; \
   } \
   CP_TIMER_IDLING_BETWEEN_TRANSFERS : coverpoint (sample_point.timer_idling_between_transfers) \
   { \
    bins CB_TIMER_1         = {1}; \
    bins CB_TIMER_2_TO_MAX  = {[2:`SVT_SPI_MAX_IDLE_TIME_BETWEEN_TRANSFER]}; \
   }

`define SVT_SPI_MONITOR_DEF_COV_UTIL_MULTILANE_COMMON_TRANSACTION(sample_point) \
   CP_TRANSFER_MODE : coverpoint (sample_point.transfer_mode)  \
   { \
    bins CB_WRITE        = {2'b01}; \
    bins CB_READ         = {2'b10}; \
   } \
   CP_INSTRUCTION_FRAME_SIZE : coverpoint (sample_point.instruction_frame_size) \
   { \
    bins CB_SIZE_0         = {0}; \
    bins CB_SIZE_1_TO_10   = {[1:10]}; \
    bins CB_SIZE_11_TO_20  = {[11:20]}; \
    bins CB_SIZE_21_TO_50  = {[21:50]}; \
   } \
   CP_ADDRESS_FRAME_SIZE : coverpoint (sample_point.address_frame_size) \
   { \
    bins CB_SIZE_0         = {0}; \
    bins CB_SIZE_1_TO_10   = {[1:10]}; \
    bins CB_SIZE_11_TO_20  = {[11:20]}; \
    bins CB_SIZE_21_TO_50  = {[21:50]}; \
   } \
   CP_DATA_FRAME_SIZE : coverpoint (sample_point.data_frame_size) \
   { \
    bins CB_SIZE_1         = {1}; \
    bins CB_SIZE_2_TO_10   = {[2:10]}; \
    bins CB_SIZE_11_TO_20  = {[11:20]}; \
    bins CB_SIZE_21_TO_50  = {[21:50]}; \
   } \
   CP_INSTRUCTION_LANE_COUNT : coverpoint (sample_point.instruction_lane_count) \
   { \
    bins CB_LANE_1         = {1}; \
    bins CB_LANE_2         = {2}; \
    bins CB_LANE_4         = {4}; \
    bins CB_LANE_8         = {8}; \
   } \
   CP_ADDRESS_LANE_COUNT : coverpoint (sample_point.address_lane_count) \
   { \
    bins CB_LANE_1         = {1}; \
    bins CB_LANE_2         = {2}; \
    bins CB_LANE_4         = {4}; \
    bins CB_LANE_8         = {8}; \
   } \
   CP_DATA_LANE_COUNT : coverpoint (sample_point.data_lane_count) \
   { \
    bins CB_LANE_1         = {1}; \
    bins CB_LANE_2         = {2}; \
    bins CB_LANE_4         = {4}; \
    bins CB_LANE_8         = {8}; \
   } \
   CP_WAIT_CYCLE_COUNT : coverpoint (sample_point.wait_cycle_count) \
   { \
    bins CB_WAIT_0         = {0}; \
    bins CB_WAIT_1_TO_4    = {[1:4]}; \
    bins CB_WAIT_5_TO_8    = {[5:8]}; \
    bins CB_WAIT_9_TO_32   = {[9:32]}; \
   }

`define SVT_SPI_MONITOR_DEF_COV_UTIL_UWIRE_COMMON_TRANSACTION(sample_point) \
   CP_TRANSFER_MODE : coverpoint (sample_point.transfer_mode)  \
   { \
    bins CB_TRASMIT        = {2'b01}; \
    bins CB_RECEIVE        = {2'b00}; \
   } \
   CP_UWIRE_TRANSFER_STATE : coverpoint (sample_point.uwire_transfer_state) \
   { \
    bins CB_SEQUENTIAL_TRANSFER = {svt_spi_types::SEQUENTIAL}; \
    bins CB_NON_SEQUENTIAL_TRANSFER = {svt_spi_types::NON_SEQUENTIAL}; \
   } \
   CP_UWIRE_DEASSERT_START_BIT : coverpoint (sample_point.uwire_deassert_start_bit) \
   { \
    bins CB_UWIRE_DEASSERT_START_BIT      = {1}; \
   } \
   CP_DATA_FRAME_SIZE : coverpoint (sample_point.data_frame_size) \
   { \
    bins CB_SIZE_0         = {0}; \
    bins CB_SIZE_1_TO_50   = {[1:50]}; \
   } \
   CP_UWIRE_CONTROL_WORD_SIZE : coverpoint (sample_point.uwire_control_word_size) \
   { \
    bins CB_UWIRE_CW_SIZE_1_TO_10    = {[1:10]}; \
    bins CB_UWIRE_CW_SIZE_11_TO_20   = {[11:20]}; \
   } \
   CP_WAIT_CYCLE_COUNT : coverpoint (sample_point.wait_cycle_count) \
   { \
    bins CB_WAIT_0         = {0}; \
    bins CB_WAIT_1         = {1}; \
   } 

