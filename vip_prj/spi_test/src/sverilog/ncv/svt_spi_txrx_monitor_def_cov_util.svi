/**
 * Following macros defines Transaction Class cover groups ,cover points , cover bins for SPI SAFE MASTER Mode
 */
`define SVT_SPI_SAFE_TXRX_MONITOR_DEF_TRANSACTION_MASTER_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
   CP_SLAVE_SELECT_ADDRESS : coverpoint (sample_point.spi_safe_frame[`SVT_SPI_SAFE_MAX_FRAME_WIDTH-1:`SVT_SPI_SAFE_MAX_FRAME_WIDTH-2]) \
   { \
    bins CB_SLAVE_SELECT_ADDR_0  = {2'b00}; \
    bins CB_SLAVE_SELECT_ADDR_1  = {2'b01}; \
    bins CB_SLAVE_SELECT_ADDR_2  = {2'b10}; \
    bins CB_SLAVE_SELECT_ADDR_3  = {2'b11}; \
   } \
   CP_SENSOR_ADDRESS    : coverpoint (sample_point.spi_safe_frame[`SVT_SPI_SAFE_MAX_FRAME_WIDTH-3:`SVT_SPI_SAFE_MAX_FRAME_WIDTH-5]) \
   { \
    bins CB_SENSOR_ADDR_0  = {3'b000}; \
    bins CB_SENSOR_ADDR_1  = {3'b001}; \
    bins CB_SENSOR_ADDR_2  = {3'b010}; \
    bins CB_SENSOR_ADDR_3  = {3'b011}; \
    bins CB_SENSOR_ADDR_4  = {3'b100}; \
    bins CB_SENSOR_ADDR_5  = {3'b101}; \
    bins CB_SENSOR_ADDR_6  = {3'b110}; \
    bins CB_SENSOR_ADDR_7  = {3'b111}; \
   } \
   CP_SPI_SAFE_FRAME_SIZE : coverpoint (sample_point.spi_safe_frame_size)\
   { \
    bins CB_SPI_SAFE_FRAME_SIZE_32  = {`SVT_SPI_SAFE_MAX_FRAME_WIDTH}; \
   } \
 endgroup

