/**
 * Following macros defines Transaction Class cover groups ,cover points , cover bins for SPI MASTER Mode
 */
`define SVT_SPI_TXRX_MONITOR_DEF_TRANSACTION_MASTER_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
   `SVT_SPI_MONITOR_DEF_COV_UTIL_COMMON_TRANSACTION(sample_point) \
   CP_TIMER_LEADING : coverpoint (sample_point.timer_leading) \
   { \
    bins CB_TIMER_1         = {1}; \
    bins CB_TIMER_2_TO_MAX  = {[2:`SVT_SPI_MAX_LEADING_TIME]}; \
   } \
   CP_TRANSFER_MODE : coverpoint (sample_point.transfer_mode)  \
   { \
    bins CB_TX_ONLY         = {2'b00}; \
    bins CB_RX_ONLY         = {2'b01}; \
    bins CB_FULL_DUPLEX     = {2'b10}; \
    bins CB_EEPROM          = {2'b11}; \
   } \
   CP_DATA_FRAME_SIZE : coverpoint (sample_point.data_frame_size) \
   { \
    bins CB_SIZE_1         = {1}; \
    bins CB_SIZE_2_TO_10   = {[2:10]}; \
    bins CB_SIZE_11_TO_20  = {[11:20]}; \
    bins CB_SIZE_21_TO_50  = {[21:50]}; \
   }  \
 endgroup

/**
 * Following macros defines Transaction Class cover groups ,cover points , cover bins for SPI SLAVE Mode
 */
`define SVT_SPI_TXRX_MONITOR_DEF_TRANSACTION_SLAVE_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
   CP_DATA_FRAME_SIZE : coverpoint (sample_point.data_frame_size) \
   { \
    bins CB_SIZE_1         = {1}; \
    bins CB_SIZE_2_TO_10   = {[2:10]}; \
    bins CB_SIZE_11_TO_20  = {[11:20]}; \
    bins CB_SIZE_21_TO_50  = {[21:50]}; \
   }  \
 endgroup
 
/**
