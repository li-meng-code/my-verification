 */
`define SVT_SPI_TXRX_MONITOR_DEF_TRANSACTION_MULTILANE_SLAVE_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
   `SVT_SPI_MONITOR_DEF_COV_UTIL_MULTILANE_COMMON_TRANSACTION(sample_point) \
