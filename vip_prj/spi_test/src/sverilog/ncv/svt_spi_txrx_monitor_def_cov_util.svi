   CP_SPI_SAFE_FRAME_SIZE : coverpoint (sample_point.spi_safe_frame_size)\
   { \
    bins CB_SPI_SAFE_FRAME_SIZE_32  = {`SVT_SPI_SAFE_MAX_FRAME_WIDTH}; \
   } \
 endgroup

/**
 * Following macros defines Configuration Class cover groups ,cover points , cover bins for SPI MASTER(Motorola Specification) Mode
 */
`define SVT_SPI_TXRX_MONITOR_DEF_CONFIGURATION_MASTER_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
    `SVT_SPI_MONITOR_DEF_COV_UTIL_COMMON_CONFIGURATION(sample_point) \
   CP_OPERATION_MODE : coverpoint (sample_point.operation_mode)  \
