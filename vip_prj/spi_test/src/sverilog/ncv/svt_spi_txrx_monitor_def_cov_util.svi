/**
 * Following macros defines configuration Class cover groups ,cover points , cover bins for SPI STD frame format
 */
`define SVT_SPI_TXRX_MONITOR_DEF_SPI_STD_COMMON_MASTER_CONFIGURATION_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
   CP_SPI_FEATURE : coverpoint(sample_point.spi_feature) \
   { \
    bins CB_MOTOROLA_SPI_FEATURE                 = {svt_spi_types::SPI}; \
    bins CB_TEXAS_INSTUMENTS_SSP_FEATURE         = {svt_spi_types::SSP}; \
    bins CB_NATIONAL_SEMICONDUCTOR_UWIRE_FEATURE = {svt_spi_types::UWIRE}; \
   } \
 endgroup

`define SVT_SPI_TXRX_MONITOR_DEF_SPI_STD_COMMON_SLAVE_CONFIGURATION_CG(group_name,sample_event,sample_point) \
  `SVT_SPI_TXRX_MONITOR_DEF_COV_UTIL_CG(group_name,sample_event) \
   CP_SPI_FEATURE : coverpoint(sample_point.spi_feature) \
   { \
    bins CB_MOTOROLA_SPI_FEATURE                 = {svt_spi_types::SPI}; \
    bins CB_TEXAS_INSTUMENTS_SSP_FEATURE         = {svt_spi_types::SSP}; \
    bins CB_NATIONAL_SEMICONDUCTOR_UWIRE_FEATURE = {svt_spi_types::UWIRE}; \
   } \
 endgroup

