   } \
   CP_TIMER_DEASSERT_SPI_INT : coverpoint (sample_point.timer_last_sample_to_spi_int_deassert) \
   { \
    bins CB_TIMER_0         = {0}; \
    bins CB_TIMER_1_TO_MAX  = {[1:`SVT_SPI_MAX_LAST_SAMPLE_TO_SPI_INT_DEASSERT]}; \
   } \
