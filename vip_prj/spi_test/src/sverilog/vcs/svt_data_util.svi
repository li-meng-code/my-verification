`ifndef GUARD_SVT_DATA_UTIL_SVI
`define GUARD_SVT_DATA_UTIL_SVI

// -------------------------------------------------------------------------
// Utility macro needed to safely convert macro parameter to string
// -------------------------------------------------------------------------

`define SVT_DATA_UTIL_ARG_TO_STRING(str) `"str`"

// -------------------------------------------------------------------------
// Strings used to provide consistency among unspecified string values
// -------------------------------------------------------------------------

`define SVT_DATA_UTIL_UNSPECIFIED "<unspecified>"

// -------------------------------------------------------------------------
// Constants used in the byte_* methods
// -------------------------------------------------------------------------

`define SVT_DATA_UTIL_BITS_PER_BYTE      8
`define SVT_DATA_UTIL_BYTES_PER_INT      4
`define SVT_DATA_UTIL_BITS_PER_INT       (`SVT_DATA_UTIL_BYTES_PER_INT*`SVT_DATA_UTIL_BITS_PER_BYTE)
`define SVT_DATA_UTIL_BYTES_PER_LONGINT  8
`define SVT_DATA_UTIL_BYTES_PER_TIME     8
`define SVT_DATA_UTIL_BYTES_PER_REALTIME 8
`define SVT_DATA_UTIL_BYTES_PER_REAL     8
`define SVT_DATA_UTIL_BYTES_PER_ENUM     1

