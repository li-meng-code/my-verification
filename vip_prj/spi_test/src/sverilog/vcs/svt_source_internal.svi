// Certain things need to be treated differently if we are using UVM 1.2 or higher, so make it easy to key off this.
`ifdef UVM_MAJOR_REV_1
`ifdef UVM_MINOR_REV_0
`define SVT_PRE_UVM_12
`elsif UVM_MINOR_REV_1
`define SVT_PRE_UVM_12
`endif
`endif

`ifdef SVT_UVM_TECHNOLOGY
`ifndef SVT_PRE_UVM_12
`define SVT_UVM_12_OR_HIGHER
`endif
`endif

// The UVM_RESOURCE_DEFINES_SVH macro was added for the 1800.2-2017 release
`ifdef SVT_UVM_TECHNOLOGY
`ifdef UVM_RESOURCE_DEFINES_SVH
`define SVT_UVM_1800_2_2017_OR_HIGHER
`endif
`endif

