
`ifndef GUARD_SPI_RESET_IF_SVI
`define GUARD_SPI_RESET_IF_SVI

/**
 * Abstract:
 * Defines an interface that provides access to a reset signal.  This
 * interface can be used to write sequences to drive the reset logic.
 */
interface spi_reset_if();

  logic reset;
  logic clk;

  modport spi_reset_modport (input clk, output reset);

endinterface

`endif // GUARD_SPI_RESET_IF_SVI

